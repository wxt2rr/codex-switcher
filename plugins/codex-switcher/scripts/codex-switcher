tui_support_interactive() {
  [[ -t 0 && -t 1 ]]
}

tui_enter_alt_screen() {
  if [[ "$TUI_INTERACTIVE" == "true" && "$TUI_ALT_SCREEN_ACTIVE" != "true" ]]; then
    # Use private mode 1049 (alternate buffer + cursor save/restore).
    printf '\033[?1049h\033[H\033[2J' 2>/dev/null || true
    TUI_ALT_SCREEN_ACTIVE="true"
  fi
}

tui_leave_alt_screen() {
  if [[ "$TUI_ALT_SCREEN_ACTIVE" == "true" ]]; then
    printf '\033[?1049l' 2>/dev/null || true
    TUI_ALT_SCREEN_ACTIVE="false"
  fi
}

tui_setup_terminal() {
  TUI_SHOULD_QUIT="false"
  if tui_support_interactive; then
    TUI_INTERACTIVE="true"
    if [[ "${TERM:-}" != "dumb" ]]; then
      TUI_COLOR_ENABLED="true"
      TUI_COLOR_BORDER=$'\033[38;5;240m'
      TUI_COLOR_TITLE=$'\033[1;38;5;255m'
      TUI_COLOR_DIM=$'\033[38;5;245m'
      TUI_COLOR_HILITE=$'\033[1;38;5;50m'
      TUI_COLOR_GOOD=$'\033[1;38;5;78m'
      TUI_COLOR_WARN=$'\033[1;38;5;220m'
      TUI_COLOR_BAD=$'\033[1;38;5;203m'
      TUI_COLOR_BAR_EMPTY_BG=$'\033[48;5;236m'
      TUI_COLOR_BAR_GOOD_BG=$'\033[48;5;71m'
      TUI_COLOR_BAR_WARN_BG=$'\033[48;5;179m'
      TUI_COLOR_BAR_BAD_BG=$'\033[48;5;167m'
      TUI_COLOR_RESET=$'\033[0m'
    else
      TUI_COLOR_ENABLED="false"
      TUI_COLOR_BORDER=""
      TUI_COLOR_TITLE=""
      TUI_COLOR_DIM=""
      TUI_COLOR_HILITE=""
      TUI_COLOR_GOOD=""
      TUI_COLOR_WARN=""
      TUI_COLOR_BAD=""
      TUI_COLOR_BAR_EMPTY_BG=""
      TUI_COLOR_BAR_GOOD_BG=""
      TUI_COLOR_BAR_WARN_BG=""
      TUI_COLOR_BAR_BAD_BG=""
      TUI_COLOR_RESET=""
    fi
    TUI_STTY_SAVED="$(stty -g 2>/dev/null || true)"
    stty -echo -icanon min 1 time 0 2>/dev/null || true
    TUI_RAW_ACTIVE="true"
    tui_enter_alt_screen
    # Disable alternate-scroll mode so touchpad/mouse wheel cannot emulate
    # up/down cursor keys inside alternate screen.
    printf '\033[?1007l' 2>/dev/null || true
    printf '\033[?25l' 2>/dev/null || true
  else
    TUI_INTERACTIVE="false"
  fi
}

tui_restore_terminal() {
  if [[ "$TUI_RAW_ACTIVE" == "true" ]]; then
    if [[ -n "$TUI_STTY_SAVED" ]]; then
      stty "$TUI_STTY_SAVED" 2>/dev/null || true
    fi
    TUI_RAW_ACTIVE="false"
  fi
  if [[ "$TUI_INTERACTIVE" == "true" ]]; then
    printf '\033[?25h\033[0m' 2>/dev/null || true
    tui_leave_alt_screen
  fi
}

tui_leave_raw_mode() {
  if [[ "$TUI_INTERACTIVE" == "true" && "$TUI_RAW_ACTIVE" == "true" ]]; then
    if [[ -n "$TUI_STTY_SAVED" ]]; then
      stty "$TUI_STTY_SAVED" 2>/dev/null || true
    fi
    TUI_RAW_ACTIVE="false"
    printf '\033[?25h' >&2 2>/dev/null || true
  fi
}

tui_enter_raw_mode() {
  if [[ "$TUI_INTERACTIVE" == "true" && "$TUI_RAW_ACTIVE" != "true" ]]; then
    stty -echo -icanon min 1 time 0 2>/dev/null || true
    TUI_RAW_ACTIVE="true"
    printf '\033[?25l' >&2 2>/dev/null || true
  fi
}

tui_clear_screen() {
  if [[ "$TUI_INTERACTIVE" == "true" ]]; then
    printf '\033[2J\033[H' >&2
  fi
}

tui_read_key() {
  local key next next2

  # Prevent SIGTTIN suspension when this process is no longer foreground.
  if ! tui_has_foreground_tty; then
    echo "quit"
    return 0
  fi

  if [[ -n "$TUI_KEY_BUFFER" ]]; then
    key="$TUI_KEY_BUFFER"
    TUI_KEY_BUFFER=""
  else
    IFS= read -rsn1 key || return 1
  fi

  # In some terminals Enter is consumed as delimiter and read returns empty key.
  if [[ -z "$key" || "$key" == $'\n' || "$key" == $'\r' ]]; then
    # Some terminals emit CRLF for Enter. Discard trailing CR/LF bytes so
    # one Enter maps to exactly one action.
    while IFS= read -rsn1 -t 0 next; do
      case "$next" in
        ""|$'\n'|$'\r')
          ;;
        *)
          TUI_KEY_BUFFER="$next"
          break
          ;;
      esac
    done
    echo "enter"
    return 0
  fi

  case "$key" in
    $'\x1b')
      # macOS bash 3.2 does not support fractional timeout for `read -t`.
      if IFS= read -rsn1 -t 1 next; then
        case "$next" in
          '[')
            IFS= read -rsn1 -t 1 next2 || true
            case "$next2" in
              A) echo "up" ;;
              B) echo "down" ;;
              C) echo "right" ;;
              D) echo "left" ;;
              *) echo "esc" ;;
            esac
            ;;
          O)
            IFS= read -rsn1 -t 1 next2 || true
            case "$next2" in
              A) echo "up" ;;
              B) echo "down" ;;
              C) echo "right" ;;
              D) echo "left" ;;
              *) echo "esc" ;;
            esac
            ;;
          *)
            echo "esc"
            ;;
        esac
      else
        echo "esc"
      fi
      ;;
    $'\n'|$'\r')
      echo "enter"
      ;;
    q|Q)
      echo "quit"
      ;;
    [0-9])
      echo "digit:$key"
      ;;
    *)
      echo "char:$key"
      ;;
  esac
}

tui_request_quit() {
  TUI_SHOULD_QUIT="true"
}

tui_quit_requested() {
  [[ "$TUI_SHOULD_QUIT" == "true" ]]
}

tui_has_foreground_tty() {
  local my_pgid tty_pgid
  my_pgid="$(ps -o pgid= -p $$ 2>/dev/null | tr -d '[:space:]')"
  tty_pgid="$(ps -o tpgid= -p $$ 2>/dev/null | tr -d '[:space:]')"
  [[ -n "$my_pgid" && -n "$tty_pgid" && "$my_pgid" == "$tty_pgid" ]]
}

tui_choose_index_with_back() {
  local title="$1"
  local info="${2:-}"
  local default_index="${3:-0}"
  shift 3 || true
  local -a options=("$@")
  local back_index

  options+=("$(tui_text "$(read_ui_lang)" back)")
  back_index=$(( ${#options[@]} - 1 ))
  tui_choose_index "$title" "$info" "$default_index" "${options[@]}"
  if [[ "$TUI_MENU_RESULT" == "$back_index" ]]; then
    TUI_MENU_RESULT="-1"
  fi
}

tui_now_epoch() {
  date +%s
}

tui_panel_open() {
  local title="$1"
  if [[ "$TUI_INTERACTIVE" == "true" ]]; then
    printf '\n' >&2
  else
    echo
  fi
  if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
    if [[ "$TUI_INTERACTIVE" == "true" ]]; then
      printf '%b┌%b %b%s%b\n' "$TUI_COLOR_BORDER" "$TUI_COLOR_RESET" "$TUI_COLOR_TITLE" "$title" "$TUI_COLOR_RESET" >&2
    else
      printf '%b┌%b %b%s%b\n' "$TUI_COLOR_BORDER" "$TUI_COLOR_RESET" "$TUI_COLOR_TITLE" "$title" "$TUI_COLOR_RESET"
    fi
  else
    if [[ "$TUI_INTERACTIVE" == "true" ]]; then
      printf '┌ %s\n' "$title" >&2
    else
      echo "┌ $title"
    fi
  fi
}

tui_panel_line() {
  local content="${1:-}"
  if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
    if [[ "$TUI_INTERACTIVE" == "true" ]]; then
      printf '%b│%b %s\n' "$TUI_COLOR_BORDER" "$TUI_COLOR_RESET" "$content" >&2
    else
      printf '%b│%b %s\n' "$TUI_COLOR_BORDER" "$TUI_COLOR_RESET" "$content"
    fi
  else
    if [[ "$TUI_INTERACTIVE" == "true" ]]; then
      printf '│ %s\n' "$content" >&2
    else
      echo "│ $content"
    fi
  fi
}

tui_panel_close() {
  if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
    if [[ "$TUI_INTERACTIVE" == "true" ]]; then
      printf '%b└%b\n' "$TUI_COLOR_BORDER" "$TUI_COLOR_RESET" >&2
    else
      printf '%b└%b\n' "$TUI_COLOR_BORDER" "$TUI_COLOR_RESET"
    fi
  else
    if [[ "$TUI_INTERACTIVE" == "true" ]]; then
      printf '└\n' >&2
    else
      echo "└"
    fi
  fi
}

tui_prompt_line() {
  local prompt="$1"
  local default_value="${2:-}"
  local value

  tui_leave_raw_mode
  if [[ "$TUI_INTERACTIVE" == "true" ]]; then
    printf "%s" "$prompt" >&2
  else
    printf "%s" "$prompt"
  fi
  if ! IFS= read -r value; then
    value=""
  fi
  [[ -n "$value" ]] || value="$default_value"
  tui_enter_raw_mode
  echo "$value"
}

tui_pause_if_interactive() {
  local lang
  [[ "$TUI_INTERACTIVE" == "true" ]] || return 0
  lang="$(read_ui_lang)"
  tui_leave_raw_mode
  printf "%s" "$(tui_text "$lang" press_enter)"
  IFS= read -r _ || true
  tui_enter_raw_mode
}

tui_render_menu() {
  local title="$1"
  local info="${2:-}"
  local selected="${3:-0}"
  shift 3 || true
  local -a options=("$@")
  local i line marker
  local lang
  lang="$(read_ui_lang)"

  tui_clear_screen
  tui_panel_open "$title"
  if [[ -n "$info" ]]; then
    while IFS= read -r line; do
      tui_panel_line "$line"
    done <<< "$info"
    tui_panel_line ""
  fi
  for i in "${!options[@]}"; do
    if [[ "$i" -eq "$selected" ]]; then
      marker="> "
      if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
        tui_panel_line "${TUI_COLOR_HILITE}${marker}$((i + 1)). ${options[$i]}${TUI_COLOR_RESET}"
      else
        tui_panel_line "$marker$((i + 1)). ${options[$i]}"
      fi
    else
      marker="  "
      tui_panel_line "$marker$((i + 1)). ${options[$i]}"
    fi
  done
  tui_panel_line ""
  if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
    tui_panel_line "${TUI_COLOR_DIM}$(tui_text "$lang" nav_hint)${TUI_COLOR_RESET}"
  else
    tui_panel_line "$(tui_text "$lang" nav_hint)"
  fi
  tui_panel_close
}

tui_terminal_cols() {
  local cols rows
  cols=""

  if [[ -n "${COLUMNS:-}" && "${COLUMNS:-}" =~ ^[0-9]+$ ]]; then
    cols="$COLUMNS"
  fi

  if [[ -z "$cols" ]]; then
    read -r rows cols < <(stty size 2>/dev/null || true)
  fi

  if [[ -z "$cols" ]]; then
    cols="$(stty size < /dev/tty 2>/dev/null | awk '{print $2}' || true)"
  fi

  if [[ -z "$cols" ]]; then
    cols="$(tput cols 2>/dev/null || true)"
  fi

  if [[ -z "$cols" || ! "$cols" =~ ^[0-9]+$ || "$cols" -lt 40 ]]; then
    cols=100
  fi
  echo "$cols"
}

tui_terminal_rows() {
  local rows cols
  rows=""

  if [[ -n "${LINES:-}" && "${LINES:-}" =~ ^[0-9]+$ ]]; then
    rows="$LINES"
  fi

  if [[ -z "$rows" ]]; then
    read -r rows cols < <(stty size 2>/dev/null || true)
  fi

  if [[ -z "$rows" ]]; then
    rows="$(stty size < /dev/tty 2>/dev/null | awk '{print $1}' || true)"
  fi

  if [[ -z "$rows" ]]; then
    rows="$(tput lines 2>/dev/null || true)"
  fi

  if [[ -z "$rows" || ! "$rows" =~ ^[0-9]+$ || "$rows" -lt 18 ]]; then
    rows=32
  fi
  echo "$rows"
}

tui_usage_percent() {
  local usage="${1:-}"
  local pct
  pct="$(printf '%s\n' "$usage" | sed -nE 's/^([0-9]+)%.*/\1/p' | head -n 1)"
  [[ -n "$pct" ]] || pct=""
  echo "$pct"
}

tui_usage_time() {
  local usage="${1:-}"
  local ts
  ts="$(printf '%s\n' "$usage" | sed -nE 's/^[0-9]+% \(([^)]+)\).*$/\1/p' | head -n 1)"
  echo "${ts:--}"
}

tui_truncate_text() {
  local text="${1:-}"
  local max_len="${2:-46}"
  if [[ "${#text}" -le "$max_len" ]]; then
    echo "$text"
    return 0
  fi
  echo "${text:0:$((max_len-3))}..."
}

tui_fit_line_visual() {
  local text="${1:-}"
  local width="${2:-40}"
  local plain
  plain="$(tui_strip_ansi "$text")"
  if (( ${#plain} <= width )); then
    echo "$text"
    return 0
  fi
  echo "$(tui_truncate_text "$plain" "$width")"
}

tui_strip_ansi() {
  printf '%s' "${1:-}" | sed -E $'s/\x1B\\[[0-9;]*[A-Za-z]//g'
}

tui_visual_len() {
  local plain
  plain="$(tui_strip_ansi "${1:-}")"
  echo "${#plain}"
}

tui_repeat_char() {
  local ch="${1:-─}"
  local count="${2:-1}"
  local out=""
  local i
  (( count < 0 )) && count=0
  for ((i=0; i<count; i++)); do
    out="${out}${ch}"
  done
  printf '%s' "$out"
}

tui_pad_visual_right() {
  local text="${1:-}"
  local width="${2:-40}"
  local len pad
  len="$(tui_visual_len "$text")"
  if (( len >= width )); then
    printf '%s' "$text"
    return 0
  fi
  pad=$((width - len))
  printf '%s%*s' "$text" "$pad" ""
}

tui_usage_bar() {
  local usage="${1:-}"
  local pct filled width color_bg
  width="${2:-14}"
  pct="$(tui_usage_percent "$usage")"
  [[ -n "$pct" ]] || { echo ""; return 0; }
  filled=$((pct * width / 100))
  (( filled < 0 )) && filled=0
  (( filled > width )) && filled=width

  if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
    if (( pct >= 90 )); then
      color_bg="$TUI_COLOR_BAR_BAD_BG"
    elif (( pct >= 70 )); then
      color_bg="$TUI_COLOR_BAR_WARN_BG"
    else
      color_bg="$TUI_COLOR_BAR_GOOD_BG"
    fi
    printf '%b%*s%b%b%*s%b' \
      "$color_bg" "$filled" "" "$TUI_COLOR_RESET" \
      "$TUI_COLOR_BAR_EMPTY_BG" "$((width - filled))" "" "$TUI_COLOR_RESET"
  else
    local i bar=""
    for ((i=0; i<width; i++)); do
      if (( i < filled )); then
        bar="${bar}#"
      else
        bar="${bar}-"
      fi
    done
    printf '%s' "$bar"
  fi
}

tui_usage_pct_label() {
  local usage="${1:-}"
  local pct
  pct="$(tui_usage_percent "$usage")"
  [[ -n "$pct" ]] || { echo "--%"; return 0; }
  if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
    if (( pct >= 90 )); then
      printf '%b%s%%%b' "$TUI_COLOR_BAD" "$pct" "$TUI_COLOR_RESET"
    elif (( pct >= 70 )); then
      printf '%b%s%%%b' "$TUI_COLOR_WARN" "$pct" "$TUI_COLOR_RESET"
    else
      printf '%b%s%%%b' "$TUI_COLOR_GOOD" "$pct" "$TUI_COLOR_RESET"
    fi
  else
    echo "${pct}%"
  fi
}

tui_target_snapshot_tsv() {
  local target="$1"
  local usage_proxy="${2:-}"
  local env account home auth_file metrics state
  local email plan usage_5h usage_weekly last_activity source

  env="$(read_current_env "$target" || true)"
  account="$(read_current_account "$target" || true)"
  home="$(env_home_path "$env")"
  auth_file="$(account_auth_path "$env" "$account")"
  [[ -f "$auth_file" ]] || auth_file="$home/auth.json"

  state="$(login_state_for_target "$target" || true)"
  metrics="$(collect_profile_metrics_tsv "$account" "$auth_file" "$home" "$usage_proxy" || true)"
  if [[ -n "$metrics" ]]; then
    IFS=$'\t' read -r email plan usage_5h usage_weekly last_activity source <<< "$metrics"
  fi

  email="${email:-($account)-}"
  plan="${plan:-unknown}"
  usage_5h="${usage_5h:--}"
  usage_weekly="${usage_weekly:--}"
  last_activity="${last_activity:--}"
  source="${source:-local}"
  [[ "$source" == "api" || "$source" == "local" ]] || source="local"

  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$env" "$home" "$account" "${state:-unknown}" "$email" "$plan" "$usage_5h" "$usage_weekly" "$last_activity" "$source"
}

tui_snapshot_kv_line() {
  local key="$1"
  local value="$2"
  local width="${3:-56}"
  local label prefix max_value plain_value safe_value
  printf -v label '%-12s' "${key}"
  prefix="  ${label} "
  max_value=$((width - ${#prefix}))
  (( max_value < 6 )) && max_value=6

  plain_value="$(tui_strip_ansi "$value")"
  safe_value="$value"
  if (( ${#plain_value} > max_value )); then
    safe_value="$(tui_truncate_text "$plain_value" "$max_value")"
  fi

  if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
    printf '%b  %s%b %s\n' "$TUI_COLOR_DIM" "$label" "$TUI_COLOR_RESET" "$safe_value"
  else
    printf '  %s %s\n' "$label" "$safe_value"
  fi
}

tui_snapshot_state_label() {
  local state="${1:-unknown}"
  if [[ "$TUI_COLOR_ENABLED" != "true" ]]; then
    echo "$state"
    return 0
  fi
  case "$state" in
    logged-in)
      printf '%b%s%b' "$TUI_COLOR_GOOD" "$state" "$TUI_COLOR_RESET"
      ;;
    *)
      printf '%b%s%b' "$TUI_COLOR_BAD" "$state" "$TUI_COLOR_RESET"
      ;;
  esac
}

tui_snapshot_rule_line() {
  local width="${1:-56}"
  local line
  line="$(tui_repeat_char "─" "$width")"
  if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
    printf '%b%s%b\n' "$TUI_COLOR_BORDER" "$line" "$TUI_COLOR_RESET"
  else
    echo "$line"
  fi
}

tui_snapshot_block() {
  local label="$1"
  local env="$2"
  local home="$3"
  local account="$4"
  local state="$5"
  local email="$6"
  local plan="$7"
  local usage_5h="$8"
  local usage_weekly="$9"
  local last_activity="${10}"
  local source="${11}"
  local mark="${12:-}"
  local width="${13:-56}"
  local pct_5h pct_week t5 tw bar5 barw account_field state_label
  local title_line

  (( width < 40 )) && width=40

  state_label="$(tui_snapshot_state_label "$state")"
  pct_5h="$(tui_usage_pct_label "$usage_5h")"
  pct_week="$(tui_usage_pct_label "$usage_weekly")"
  t5="$(tui_usage_time "$usage_5h")"
  tw="$(tui_usage_time "$usage_weekly")"
  bar5="$(tui_usage_bar "$usage_5h" 12)"
  barw="$(tui_usage_bar "$usage_weekly" 12)"

  account_field="$account"
  [[ -n "$mark" ]] && account_field="${account_field} ${mark}"

  if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
    title_line="${TUI_COLOR_HILITE}●${TUI_COLOR_RESET} ${TUI_COLOR_TITLE}[${label}] ${env}/${account}${TUI_COLOR_RESET} ${state_label}"
  else
    title_line="[${label}] ${env}/${account} (${state_label})"
  fi

  title_line="$(tui_truncate_text "$title_line" "$width")"
  echo "$title_line"
  tui_snapshot_rule_line "$width"
  tui_snapshot_kv_line "ENV" "$env" "$width"
  tui_snapshot_kv_line "HOME" "$home" "$width"
  tui_snapshot_kv_line "ACCOUNT" "$account_field" "$width"
  tui_snapshot_kv_line "EMAIL" "$email" "$width"
  tui_snapshot_kv_line "PLAN" "$plan" "$width"
  tui_snapshot_kv_line "5H USAGE" "${pct_5h}  ${bar5}  ${t5}" "$width"
  tui_snapshot_kv_line "WEEKLY USAGE" "${pct_week}  ${barw}  ${tw}" "$width"
  tui_snapshot_kv_line "LAST ACTIVITY" "$last_activity" "$width"
  tui_snapshot_kv_line "SOURCE" "$source" "$width"
}

tui_print_two_col_blocks() {
  local left_block="$1"
  local right_block="$2"
  local width="${3:-56}"
  local sep i max
  local -a left_lines=()
  local -a right_lines=()
  local left_line right_line

  while IFS= read -r left_line; do
    left_lines+=("$left_line")
  done <<< "$left_block"

  while IFS= read -r right_line; do
    right_lines+=("$right_line")
  done <<< "$right_block"

  max="${#left_lines[@]}"
  if (( ${#right_lines[@]} > max )); then
    max="${#right_lines[@]}"
  fi

  if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
    sep=" ${TUI_COLOR_BORDER}│${TUI_COLOR_RESET} "
  else
    sep=" │ "
  fi

  for ((i=0; i<max; i++)); do
    left_line="${left_lines[$i]:-}"
    right_line="${right_lines[$i]:-}"
    printf '%s%s%s\n' "$(tui_pad_visual_right "$left_line" "$width")" "$sep" "$right_line"
  done
}

tui_snapshot_stack_separator() {
  local cols width
  cols="$(tui_terminal_cols)"
  width=$((cols - 4))
  (( width > 76 )) && width=76
  (( width < 40 )) && width=40
  tui_snapshot_rule_line "$width"
}

tui_snapshot_block_compact() {
  local env="$1"
  local account="$2"
  local state="$3"
  local email="$4"
  local plan="$5"
  local usage_5h="$6"
  local usage_weekly="$7"
  local last_activity="$8"
  local source="$9"
  local mark="${10:-}"
  local width="${11:-42}"
  local inner title state_label pct_5h pct_week t5 tw bar5 barw line2 line3 line4 line5 line
  local top bottom

  (( width < 34 )) && width=34
  inner=$((width - 2))
  (( inner < 20 )) && inner=20
  state_label="$(tui_snapshot_state_label "$state")"
  pct_5h="$(tui_usage_pct_label "$usage_5h")"
  pct_week="$(tui_usage_pct_label "$usage_weekly")"
  t5="$(tui_usage_time "$usage_5h")"
  tw="$(tui_usage_time "$usage_weekly")"
  bar5="$(tui_usage_bar "$usage_5h" 8)"
  barw="$(tui_usage_bar "$usage_weekly" 8)"

  if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
    title="${TUI_COLOR_HILITE}●${TUI_COLOR_RESET} ${TUI_COLOR_TITLE}${account}${TUI_COLOR_RESET}${mark} ${state_label}"
  else
    title="${account}${mark} ${state}"
  fi
  line2="${email}"
  line3="plan:${plan}  src:${source}"
  line4="5H  ${pct_5h} ${bar5} ${t5}"
  line5="WK  ${pct_week} ${barw} ${tw}"

  top="┌$(tui_repeat_char "─" "$inner")┐"
  bottom="└$(tui_repeat_char "─" "$inner")┘"
  if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
    top="${TUI_COLOR_BORDER}${top}${TUI_COLOR_RESET}"
    bottom="${TUI_COLOR_BORDER}${bottom}${TUI_COLOR_RESET}"
  fi

  echo "$top"
  for line in "$title" "$line2" "$line3" "$line4" "$line5"; do
    line="$(tui_fit_line_visual "$line" "$inner")"
    line="$(tui_pad_visual_right "$line" "$inner")"
    if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
      printf '%b│%b%s%b│%b\n' "$TUI_COLOR_BORDER" "$TUI_COLOR_RESET" "$line" "$TUI_COLOR_BORDER" "$TUI_COLOR_RESET"
    else
      printf '│%s│\n' "$line"
    fi
  done
  echo "$bottom"
}

tui_print_blocks_grid_files() {
  local width="$1"
  local line_count="${2:-7}"
  shift 2
  local -a files=("$@")
  local total cols ncols sep sepw start end line i text

  total="${#files[@]}"
  (( total > 0 )) || return 0

  cols="$(tui_terminal_cols)"
  sepw=0
  ncols=$(( (cols + sepw) / (width + sepw) ))
  (( ncols < 1 )) && ncols=1
  (( ncols > total )) && ncols="$total"

  sep=""

  for ((start=0; start<total; start+=ncols)); do
    end=$((start + ncols - 1))
    (( end >= total )) && end=$((total - 1))
    for ((line=1; line<=line_count; line++)); do
      for ((i=start; i<=end; i++)); do
        text="$(sed -n "${line}p" "${files[$i]}" 2>/dev/null || true)"
        if (( i > start )); then
          # Remove only the left border glyph for merged cards.
          # Keep trailing ANSI sequences so title/bullet colors stay intact.
          text="$(printf '%s' "$text" | sed -E $'s/^((\\x1B\\[[0-9;]*m)*)[│┌└]/\\1/')"
        fi
        text="$(tui_pad_visual_right "$text" "$width")"
        if (( i == start )); then
          printf '%s' "$text"
        else
          printf '%s%s' "$sep" "$text"
        fi
      done
      printf '\n'
    done
    if (( end < total - 1 )); then
      echo
    fi
  done
}

tui_status_env_heading() {
  local env="$1"
  if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
    printf '%b%s%b\n' "$TUI_COLOR_TITLE" "ENV: $env" "$TUI_COLOR_RESET"
  else
    echo "ENV: $env"
  fi
}

tui_account_snapshot_tsv() {
  local env="$1"
  local account="$2"
  local usage_proxy="${3:-}"
  local home auth_file metrics state
  local email plan usage_5h usage_weekly last_activity source

  home="$(env_home_path "$env")"
  auth_file="$(account_auth_path "$env" "$account")"
  [[ -f "$auth_file" ]] || auth_file="$home/auth.json"

  if account_has_auth "$env" "$account"; then
    state="logged-in"
  else
    state="not-logged-in"
  fi

  metrics="$(collect_profile_metrics_tsv "$account" "$auth_file" "$home" "$usage_proxy" || true)"
  if [[ -n "$metrics" ]]; then
    IFS=$'\t' read -r email plan usage_5h usage_weekly last_activity source <<< "$metrics"
  fi

  email="${email:-($account)-}"
  plan="${plan:-unknown}"
  usage_5h="${usage_5h:--}"
  usage_weekly="${usage_weekly:--}"
  last_activity="${last_activity:--}"
  source="${source:-local}"
  [[ "$source" == "api" || "$source" == "local" ]] || source="local"

  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$env" "$home" "$account" "$state" "$email" "$plan" "$usage_5h" "$usage_weekly" "$last_activity" "$source"
}

tui_home_accounts_snapshot() {
  local usage_info usage_proxy cols colw
  local cli_env cli_account app_env app_account
  local env account mark any
  local s_env s_home s_account s_state s_email s_plan s_5h s_week s_last s_source
  local max_parallel
  local tmp_dir
  local -a all_envs=()
  local -a all_accounts=()
  local -a worker_pids=()
  local -a block_files=()
  local -a env_block_files=()
  local idx

  usage_info="$(resolve_usage_proxy_with_source || true)"
  usage_proxy=""
  if [[ -n "$usage_info" ]]; then
    IFS=$'\t' read -r _ usage_proxy <<< "$usage_info"
  fi

  cli_env="$(read_current_env cli || true)"
  cli_account="$(read_current_account cli || true)"
  app_env="$(read_current_env app || true)"
  app_account="$(read_current_account app || true)"

  cols="$(tui_terminal_cols)"
  # Prefer horizontal density inside one env group.
  colw=28
  (( cols < 90 )) && colw=30

  max_parallel="${CODEX_SWITCHER_STATUS_PARALLELISM:-6}"
  [[ "$max_parallel" =~ ^[0-9]+$ ]] || max_parallel=6
  (( max_parallel < 1 )) && max_parallel=1

  tmp_dir="$(mktemp -d /tmp/codex-sw-status-snapshot.XXXXXX)"

  any=0
  while IFS= read -r env; do
    while IFS= read -r account; do
      all_envs+=("$env")
      all_accounts+=("$account")
      idx=$(( ${#all_envs[@]} - 1 ))
      (
        tui_account_snapshot_tsv "$env" "$account" "$usage_proxy" > "$tmp_dir/metric.$idx.tsv"
      ) &
      worker_pids+=("$!")
      if (( ${#worker_pids[@]} >= max_parallel )); then
        wait "${worker_pids[0]}" 2>/dev/null || true
        worker_pids=("${worker_pids[@]:1}")
      fi
    done < <(list_accounts_for_env "$env")
  done < <(list_env_names | sort -u)

  for idx in "${worker_pids[@]}"; do
    wait "$idx" 2>/dev/null || true
  done

  for idx in "${!all_envs[@]}"; do
    any=1
    IFS=$'\t' read -r s_env s_home s_account s_state s_email s_plan s_5h s_week s_last s_source < "$tmp_dir/metric.$idx.tsv" || true
    s_env="${s_env:-${all_envs[$idx]}}"
    s_account="${s_account:-${all_accounts[$idx]}}"
    s_state="${s_state:-not-logged-in}"
    s_email="${s_email:--}"
    s_plan="${s_plan:-unknown}"
    s_5h="${s_5h:---}"
    s_week="${s_week:---}"
    s_last="${s_last:---}"
    s_source="${s_source:-local}"
    s_home="$(display_path_for_output "$s_home")"
    mark=""
    env="${all_envs[$idx]}"
    account="${all_accounts[$idx]}"
    [[ "$env" == "$cli_env" && "$account" == "$cli_account" ]] && mark="${mark} [cli]"
    [[ "$env" == "$app_env" && "$account" == "$app_account" ]] && mark="${mark} [app]"
    tui_snapshot_block_compact "$s_env" "$s_account" "$s_state" "$s_email" "$s_plan" "$s_5h" "$s_week" "$s_last" "$s_source" "$mark" "$colw" > "$tmp_dir/block.$idx.txt"
    block_files+=("$tmp_dir/block.$idx.txt")
  done

  if [[ "$any" -eq 0 ]]; then
    echo "  No accounts found."
    rm -rf "$tmp_dir"
    return 0
  fi

  while IFS= read -r env; do
    env_block_files=()
    for idx in "${!all_envs[@]}"; do
      if [[ "${all_envs[$idx]}" == "$env" ]]; then
        env_block_files+=("${block_files[$idx]}")
      fi
    done
    (( ${#env_block_files[@]} > 0 )) || continue
    tui_status_env_heading "$env"
    tui_print_blocks_grid_files "$colw" "7" "${env_block_files[@]}"
    echo
  done < <(list_env_names | sort -u)

  rm -rf "$tmp_dir"
}

tui_choose_index() {
  local title="$1"
  local info="${2:-}"
  local default_index="${3:-0}"
  shift 3 || true
  local -a options=("$@")
  local max idx choice key d
  local lang
  lang="$(read_ui_lang)"

  TUI_MENU_RESULT="-1"
  max="${#options[@]}"
  (( max > 0 )) || return 0
  idx="$default_index"
  (( idx >= 0 && idx < max )) || idx=0

  if [[ "$TUI_INTERACTIVE" != "true" ]]; then
    while true; do
      tui_panel_open "$title"
      if [[ -n "$info" ]]; then
        while IFS= read -r choice; do
          tui_panel_line "$choice"
        done <<< "$info"
        tui_panel_line ""
      fi
      for d in "${!options[@]}"; do
        printf '%2d) %s\n' "$((d + 1))" "${options[$d]}"
      done
      printf "%s" "$(tui_text "$lang" choose)"
      if ! IFS= read -r choice; then
        TUI_MENU_RESULT="-1"
        return 0
      fi
      choice="$(echo "${choice:-}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
      if [[ -z "$choice" ]]; then
        TUI_MENU_RESULT="$idx"
        return 0
      fi
      case "$choice" in
        q|Q)
          tui_request_quit
          TUI_MENU_RESULT="-1"
          return 0
          ;;
      esac
      if [[ "$choice" =~ ^[0-9]+$ ]]; then
        d=$((choice - 1))
        if (( d >= 0 && d < max )); then
          TUI_MENU_RESULT="$d"
          return 0
        fi
      fi
      echo "$(tui_text "$lang" invalid_choice)$choice"
    done
  fi

  while true; do
    tui_render_menu "$title" "$info" "$idx" "${options[@]}"
    key="$(tui_read_key || true)"
    [[ -n "$key" ]] || continue
    case "$key" in
      up)
        idx=$(( (idx - 1 + max) % max ))
        ;;
      down)
        idx=$(( (idx + 1) % max ))
        ;;
      enter)
        TUI_MENU_RESULT="$idx"
        return 0
        ;;
      quit)
        tui_request_quit
        TUI_MENU_RESULT="-1"
        return 0
        ;;
      digit:*)
        d="${key#digit:}"
        if [[ "$d" =~ ^[0-9]+$ ]]; then
          d=$((d - 1))
          if (( d >= 0 && d < max )); then
            TUI_MENU_RESULT="$d"
            return 0
          fi
        fi
        ;;
    esac
  done
}

tui_execute_subcommand() {
  local -a args=("$@")
  local rc
  local lang
  lang="$(read_ui_lang)"

  if [[ "${#args[@]}" -eq 0 ]]; then
    return 0
  fi

  tui_leave_raw_mode
  set +e
  CODEX_SWITCHER_SKIP_UPDATE_CHECK=true "$SCRIPT_DIR/codex-switcher" "${args[@]}"
  rc=$?
  set -e

  echo
  echo "$(tui_text "$lang" exit_code_prefix)$rc]"
  # Avoid SIGTTIN suspends on some shells/TTY setups after app launch.
  # Opt-in old blocking behavior via CODEX_SWITCHER_TUI_WAIT_ENTER=true.
  if [[ "$TUI_INTERACTIVE" == "true" ]]; then
    if [[ "${CODEX_SWITCHER_TUI_WAIT_ENTER:-false}" == "true" ]] && tui_has_foreground_tty; then
      printf "%s" "$(tui_text "$lang" press_enter)"
      IFS= read -r _ || true
    fi
    tui_enter_raw_mode
  fi
}

tui_execute_subcommand_detached() {
  local -a args=("$@")
  local cmdline
  if [[ "${#args[@]}" -eq 0 ]]; then
    return 0
  fi

  # Fully detach from current TTY so TUI can stay interactive.
  nohup env CODEX_SWITCHER_SKIP_UPDATE_CHECK=true "$SCRIPT_DIR/codex-switcher" "${args[@]}" </dev/null >>"$SWITCH_LOG" 2>&1 &
  cmdline="$(printf '%q ' "$SCRIPT_NAME" "${args[@]}")"
  echo "已在后台执行: ${cmdline% }"
}

tui_select_env() {
  local default_env="${1:-$(read_current_env cli || true)}"
  local include_default="${2:-true}"
  local info
  local idx env
  local -a envs=()

  while IFS= read -r env; do
    [[ "$include_default" != "true" && "$env" == "$DEFAULT_ENV_NAME" ]] && continue
    envs+=("$env")
  done < <(list_env_names | sort -u)

  if [[ "${#envs[@]}" -eq 0 ]]; then
    return 1
  fi

  idx=0
  for env in "${!envs[@]}"; do
    if [[ "${envs[$env]}" == "$default_env" ]]; then
      idx="$env"
      break
    fi
  done
  info="$(tui_text "$(read_ui_lang)" select_env_title)"
  tui_choose_index_with_back "$info" "" "$idx" "${envs[@]}"
  [[ "$TUI_MENU_RESULT" == "-1" ]] && return 1
  echo "${envs[$TUI_MENU_RESULT]}"
}

tui_account_slots_for_env() {
  local env="$1"
  local dir="$ACCOUNTS_DIR/$env"
  if [[ -d "$dir" ]]; then
    find "$dir" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; | while IFS= read -r account; do
      validate_name_noexit "$account" || continue
      echo "$account"
    done
  fi
  if account_has_auth "$env" "$DEFAULT_ACCOUNT_NAME"; then
    echo "$DEFAULT_ACCOUNT_NAME"
  fi
}

tui_select_account() {
  local env="$1"
  local default_account="${2:-$(read_current_account cli || true)}"
  local require_auth="${3:-true}"
  local idx account status
  local -a accounts=()
  local -a labels=()

  while IFS= read -r account; do
    if [[ "$require_auth" == "true" ]] && ! account_has_auth "$env" "$account"; then
      continue
    fi
    accounts+=("$account")
  done < <(tui_account_slots_for_env "$env" | sort -u)

  if [[ "${#accounts[@]}" -eq 0 ]]; then
    echo "$(tui_text "$(read_ui_lang)" no_logged_account)" >&2
    tui_pause_if_interactive
    return 1
  fi

  idx=0
  for account in "${!accounts[@]}"; do
    [[ "${accounts[$account]}" == "$default_account" ]] && idx="$account" && break
  done

  for account in "${accounts[@]}"; do
    if account_has_auth "$env" "$account"; then
      status="$(tui_text "$(read_ui_lang)" status_logged_in)"
    else
      status="$(tui_text "$(read_ui_lang)" status_not_logged_in)"
    fi
    labels+=("$account [$status]")
  done

  tui_choose_index_with_back "$(tui_text "$(read_ui_lang)" select_account_title) (env=$env)" "" "$idx" "${labels[@]}"
  [[ "$TUI_MENU_RESULT" == "-1" ]] && return 1
  echo "${accounts[$TUI_MENU_RESULT]}"
}

tui_choose_target() {
  local allow_both="${1:-false}"
  local -a options=()
  local -a values=()
  local idx

  options+=("$(tui_text "$(read_ui_lang)" target_cli)")
  values+=("cli")
  options+=("$(tui_text "$(read_ui_lang)" target_app)")
  values+=("app")
  if [[ "$allow_both" == "true" ]]; then
    options+=("$(tui_text "$(read_ui_lang)" target_both)")
    values+=("both")
  fi
  tui_choose_index_with_back "$(tui_text "$(read_ui_lang)" select_target_title)" "" "0" "${options[@]}"
  [[ "$TUI_MENU_RESULT" == "-1" ]] && return 1
  echo "${values[$TUI_MENU_RESULT]}"
}

tui_action_switch() {
  local target="" env="" account="" launch_mode="none" launch_idx launch_target_label
  local stage=0

  while true; do
    tui_quit_requested && return 1
    case "$stage" in
      0)
        target="$(tui_choose_target false)" || {
          tui_quit_requested && return 1
          return 1
        }
        stage=1
        ;;
      1)
        env="$(tui_select_env "$(read_current_env "$target" || true)")" || {
          tui_quit_requested && return 1
          stage=0
          continue
        }
        stage=2
        ;;
      2)
        account="$(tui_select_account "$env" "$(read_current_account "$target" || true)" true)" || {
          tui_quit_requested && return 1
          stage=1
          continue
        }
        stage=3
        ;;
      3)
        case "$target" in
          cli) launch_target_label="$(tui_text "$(read_ui_lang)" target_cli)" ;;
          app) launch_target_label="$(tui_text "$(read_ui_lang)" target_app)" ;;
          *) launch_target_label="$target" ;;
        esac
        tui_choose_index_with_back "$(tui_text "$(read_ui_lang)" select_launch_title) ${launch_target_label}" "" "0" \
          "$(tui_text "$(read_ui_lang)" launch_yes)" \
          "$(tui_text "$(read_ui_lang)" launch_switch_only)"
        launch_idx="$TUI_MENU_RESULT"
        if [[ "$launch_idx" == "-1" ]]; then
          tui_quit_requested && return 1
          stage=2
          continue
        fi
        case "$launch_idx" in
          0) launch_mode="$target" ;;
          1) launch_mode="none" ;;
          *) launch_mode="none" ;;
        esac
        if [[ "$launch_mode" == "none" ]]; then
          tui_execute_subcommand ac use "$account" --env "$env" -t "$target" --no-launch
          return 0
        fi
        if [[ "$target" == "app" ]]; then
          tui_execute_subcommand_detached ac use "$account" --env "$env" -t "$target" --launch
        else
          tui_execute_subcommand ac use "$account" --env "$env" -t "$target" --launch
        fi
        return 0
        ;;
    esac
  done
}

tui_action_login() {
  local prefer_env="${1:-$(read_current_env cli || true)}"
  local env account mode mode_idx
  tui_panel_open "$(tui_text "$(read_ui_lang)" login_title)"

  env="$(tui_select_env "$prefer_env")" || return 1

  account="$(tui_prompt_line "$(tui_text "$(read_ui_lang)" login_account_prompt)" "")"
  account="$(normalize_name_input "$account")"
  account="$(echo "${account:-}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
  if ! validate_name_noexit "$account"; then
    echo "$(tui_text "$(read_ui_lang)" invalid_choice)$account"
    tui_pause_if_interactive
    return 1
  fi

  tui_choose_index_with_back "$(tui_text "$(read_ui_lang)" login_mode_title)" "" "0" \
    "$(tui_text "$(read_ui_lang)" login_mode_auth)" \
    "$(tui_text "$(read_ui_lang)" login_mode_apikey)"
  mode_idx="$TUI_MENU_RESULT"
  [[ "$mode_idx" == "-1" ]] && return 1
  [[ "$mode_idx" == "1" ]] && mode="apikey" || mode="auth"

  if [[ "$mode" == "apikey" ]]; then
    tui_execute_subcommand ac login "$account" --env "$env" -t both --mode apikey
  else
    tui_execute_subcommand ac login "$account" --env "$env" -t both
  fi
}

tui_action_env_create() {
  local name src_idx src env_from
  tui_panel_open "$(tui_text "$(read_ui_lang)" envs_create)"
  name="$(tui_prompt_line "$(tui_text "$(read_ui_lang)" env_name_prompt)" "")"
  name="$(normalize_name_input "$name")"
  name="$(echo "${name:-}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
  if ! validate_env_name_noexit "$name" || [[ "$name" == "$DEFAULT_ENV_NAME" ]]; then
    echo "$(tui_text "$(read_ui_lang)" invalid_choice)$name"
    tui_pause_if_interactive
    return 1
  fi

  tui_choose_index_with_back "$(tui_text "$(read_ui_lang)" env_source_title)" "" "0" \
    "$(tui_text "$(read_ui_lang)" env_source_default)" \
    "$(tui_text "$(read_ui_lang)" env_source_empty)" \
    "$(tui_text "$(read_ui_lang)" env_source_other)"
  src_idx="$TUI_MENU_RESULT"
  [[ "$src_idx" == "-1" ]] && return 1
  case "$src_idx" in
    0)
      tui_execute_subcommand env new "$name"
      ;;
    1)
      tui_execute_subcommand env new "$name" --empty
      ;;
    *)
      env_from="$(tui_select_env "$(read_current_env cli || true)")" || return 1
      tui_execute_subcommand env new "$name" --from "$env_from"
      ;;
  esac
}

tui_action_env_delete() {
  local env
  env="$(tui_select_env "$(read_current_env cli || true)" false)" || {
    echo "$(tui_text "$(read_ui_lang)" invalid_choice)$DEFAULT_ENV_NAME"
    tui_pause_if_interactive
    return 1
  }
  tui_execute_subcommand env rm "$env"
}

tui_action_proxy() {
  local info choice input usage_info source value
  local default_manual=""
  while true; do
    usage_info="$(resolve_usage_proxy_with_source || true)"
    source=""
    value=""
    if [[ -n "$usage_info" ]]; then
      IFS=$'\t' read -r source value <<< "$usage_info"
    fi

    case "$source" in
      manual)
        info="Current: manual ($value)"
        default_manual="$value"
        ;;
      auto-env)
        info="Current: auto-detected from env ($value)"
        ;;
      auto-system)
        info="Current: auto-detected from system ($value)"
        ;;
      *)
        info="Current: auto-detect (no proxy detected)"
        ;;
    esac

    tui_choose_index_with_back "$(tui_text "$(read_ui_lang)" proxy_title)" "$info" "0" \
      "$(tui_text "$(read_ui_lang)" proxy_auto)" \
      "$(tui_text "$(read_ui_lang)" proxy_manual)"
    choice="$TUI_MENU_RESULT"
    [[ "$choice" == "-1" ]] && return 0
    case "$choice" in
      0)
        tui_execute_subcommand ops proxy off
        ;;
      1)
        input="$(tui_prompt_line "$(tui_text "$(read_ui_lang)" proxy_prompt)" "$default_manual")"
        input="$(echo "${input:-}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        [[ -n "$input" ]] || continue
        tui_execute_subcommand ops proxy "$input"
        ;;
    esac
  done
}

tui_action_lang() {
  local idx langs current i
  local -a opts=()
  local -a vals=(zh en ja)
  current="$(read_ui_lang)"
  for i in "${!vals[@]}"; do
    if [[ "${vals[$i]}" == "$current" ]]; then
      opts+=("${vals[$i]} ($(tui_text "$current" default_prefix))")
      idx="$i"
    else
      opts+=("${vals[$i]}")
    fi
  done
  idx="${idx:-0}"
  tui_choose_index_with_back "$(tui_text "$current" lang_title)" "$(tui_text "$current" lang_current_prefix): $current" "$idx" "${opts[@]}"
  langs="$TUI_MENU_RESULT"
  [[ "$langs" == "-1" ]] && return 0
  tui_execute_subcommand lang "${vals[$langs]}"
}

tui_action_accounts() {
  local action target env account stage
  while true; do
    tui_quit_requested && return 0
    tui_choose_index "$(tui_text "$(read_ui_lang)" accounts_title)" "" "0" \
      "$(tui_text "$(read_ui_lang)" accounts_use)" \
      "$(tui_text "$(read_ui_lang)" accounts_login)" \
      "$(tui_text "$(read_ui_lang)" accounts_logout)" \
      "$(tui_text "$(read_ui_lang)" accounts_delete)" \
      "$(tui_text "$(read_ui_lang)" accounts_back)"
    action="$TUI_MENU_RESULT"
    [[ "$action" == "-1" ]] && return 0
    case "$action" in
      0)
        stage=0
        while true; do
          tui_quit_requested && return 0
          case "$stage" in
            0)
              target="$(tui_choose_target false)" || {
                tui_quit_requested && return 0
                break
              }
              stage=1
              ;;
            1)
              env="$(tui_select_env "$(read_current_env "$target" || true)")" || {
                tui_quit_requested && return 0
                stage=0
                continue
              }
              stage=2
              ;;
            2)
              account="$(tui_select_account "$env" "$(read_current_account "$target" || true)" true)" || {
                tui_quit_requested && return 0
                stage=1
                continue
              }
              tui_execute_subcommand ac use "$account" --env "$env" -t "$target" --no-launch
              break
              ;;
          esac
        done
        ;;
      1)
        tui_action_login "$(read_current_env cli || true)" || true
        ;;
      2)
        stage=0
        while true; do
          tui_quit_requested && return 0
          case "$stage" in
            0)
              target="$(tui_choose_target true)" || {
                tui_quit_requested && return 0
                break
              }
              stage=1
              ;;
            1)
              env="$(tui_select_env "$(read_current_env cli || true)")" || {
                tui_quit_requested && return 0
                stage=0
                continue
              }
              stage=2
              ;;
            2)
              account="$(tui_select_account "$env" "$(read_current_account cli || true)" false)" || {
                tui_quit_requested && return 0
                stage=1
                continue
              }
              tui_execute_subcommand ac logout "$account" --env "$env" -t "$target"
              break
              ;;
          esac
        done
        ;;
      3)
        stage=0
        while true; do
          tui_quit_requested && return 0
          case "$stage" in
            0)
              env="$(tui_select_env "$(read_current_env cli || true)")" || {
                tui_quit_requested && return 0
                break
              }
              stage=1
              ;;
            1)
              account="$(tui_select_account "$env" "$(read_current_account cli || true)" false)" || {
                tui_quit_requested && return 0
                stage=0
                continue
              }
              tui_execute_subcommand ac rm "$account" --env "$env"
              break
              ;;
          esac
        done
        ;;
      *)
        return 0
        ;;
    esac
  done
}

tui_action_envs() {
  local action
  while true; do
    tui_quit_requested && return 0
    tui_choose_index "$(tui_text "$(read_ui_lang)" envs_title)" "" "0" \
      "$(tui_text "$(read_ui_lang)" envs_create)" \
      "$(tui_text "$(read_ui_lang)" envs_delete)" \
      "$(tui_text "$(read_ui_lang)" envs_back)"
    action="$TUI_MENU_RESULT"
    [[ "$action" == "-1" ]] && return 0
    case "$action" in
      0)
        tui_action_env_create || true
        ;;
      1)
        tui_action_env_delete || true
        ;;
      *)
        return 0
        ;;
    esac
  done
}

tui_fetch_home_snapshot_with_loading() {
  local snapshot tmp pid rc i frame
  local -a frames=("◐" "◓" "◑" "◒")

  if [[ "$TUI_INTERACTIVE" != "true" ]]; then
    tui_home_accounts_snapshot
    return 0
  fi

  tmp="$(mktemp /tmp/codex-sw-home-snapshot.XXXXXX)"
  (
    tui_home_accounts_snapshot >"$tmp"
  ) &
  pid=$!
  i=0
  while kill -0 "$pid" 2>/dev/null; do
    frame="${frames[$((i % ${#frames[@]}))]}"
    tui_render_status_loading "$frame"
    sleep 0.12
    i=$((i + 1))
  done

  set +e
  wait "$pid"
  rc=$?
  set -e

  if [[ "$rc" -eq 0 ]]; then
    snapshot="$(cat "$tmp" 2>/dev/null || true)"
    rm -f "$tmp"
    printf '%s' "$snapshot"
    return 0
  fi

  rm -f "$tmp"
  return 1
}

tui_home_accounts_snapshot_cache_clear() {
  TUI_HOME_SNAPSHOT_CACHE=""
  TUI_HOME_SNAPSHOT_CACHE_TS="0"
  TUI_HOME_SNAPSHOT_RENDER=""
}

tui_home_accounts_snapshot_cached() {
  local now age snapshot
  now="$(tui_now_epoch)"

  if [[ -n "$TUI_HOME_SNAPSHOT_CACHE" && "$TUI_HOME_SNAPSHOT_CACHE_TS" =~ ^[0-9]+$ ]]; then
    age=$((now - TUI_HOME_SNAPSHOT_CACHE_TS))
    if (( age >= 0 && age < TUI_HOME_SNAPSHOT_CACHE_TTL )); then
      TUI_HOME_SNAPSHOT_RENDER="$TUI_HOME_SNAPSHOT_CACHE"
      return 0
    fi
  fi

  snapshot="$(tui_fetch_home_snapshot_with_loading || true)"
  if [[ -n "$snapshot" ]]; then
    TUI_HOME_SNAPSHOT_CACHE="$snapshot"
    TUI_HOME_SNAPSHOT_CACHE_TS="$now"
    TUI_HOME_SNAPSHOT_RENDER="$snapshot"
    return 0
  fi

  TUI_HOME_SNAPSHOT_RENDER="$TUI_HOME_SNAPSHOT_CACHE"
}

tui_render_status_loading() {
  local spinner="${1:-◐}"
  local lang info
  lang="$(read_ui_lang)"
  info="$(tui_text "$lang" home_accounts_title)
${spinner} $(tui_text "$lang" home_loading)"

  tui_render_menu "codex-sw ─ $(tui_text "$lang" home_opt_status)" "$info" "0" \
    "$(tui_text "$lang" back)"
}

tui_status_snapshot_line_count() {
  local snapshot="${1:-}"
  if [[ -z "$snapshot" ]]; then
    echo 0
    return 0
  fi
  printf '%s\n' "$snapshot" | awk 'END{print NR+0}'
}

tui_render_status_scrolled() {
  local snapshot="${1:-}"
  local offset="${2:-0}"
  local rows view_lines total_lines max_offset start end
  local lang
  lang="$(read_ui_lang)"

  rows="$(tui_terminal_rows)"
  view_lines=$((rows - 10))
  (( view_lines < 6 )) && view_lines=6

  total_lines="$(tui_status_snapshot_line_count "$snapshot")"
  max_offset=$((total_lines - view_lines))
  (( max_offset < 0 )) && max_offset=0
  (( offset < 0 )) && offset=0
  (( offset > max_offset )) && offset="$max_offset"

  start=$((offset + 1))
  end=$((offset + view_lines))

  if [[ "$TUI_INTERACTIVE" == "true" ]]; then
    # Lighter redraw than full-screen clear to reduce visible flicker.
    printf '\033[H\033[J' >&2
  fi
  if [[ "$TUI_INTERACTIVE" == "true" ]]; then
    printf 'codex-sw ─ %s\n' "$(tui_text "$lang" home_opt_status)" >&2
    printf '\n' >&2
    if [[ -n "$snapshot" ]]; then
      printf '%s\n' "$snapshot" | sed -n "${start},${end}p" >&2
    else
      printf 'No data\n' >&2
    fi
    printf '\n' >&2
    if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
      printf '%b%s%b\n' "$TUI_COLOR_DIM" "↑/↓ scroll  r refresh  Esc/q back" "$TUI_COLOR_RESET" >&2
    else
      printf '%s\n' "↑/↓ scroll  r refresh  Esc/q back" >&2
    fi
  else
    printf 'codex-sw ─ %s\n' "$(tui_text "$lang" home_opt_status)"
    printf '\n'
    if [[ -n "$snapshot" ]]; then
      printf '%s\n' "$snapshot" | sed -n "${start},${end}p"
    else
      printf 'No data\n'
    fi
    printf '\n'
    printf '%s\n' "↑/↓ scroll  r refresh  Esc/q back"
  fi
}

tui_action_status() {
  local snapshot key offset total_lines rows view_lines max_offset
  while true; do
    tui_quit_requested && return 0
    tui_render_status_loading
    tui_home_accounts_snapshot_cached
    snapshot="$TUI_HOME_SNAPSHOT_RENDER"
    offset=0
    while true; do
      rows="$(tui_terminal_rows)"
      view_lines=$((rows - 10))
      (( view_lines < 6 )) && view_lines=6
      total_lines="$(tui_status_snapshot_line_count "$snapshot")"
      max_offset=$((total_lines - view_lines))
      (( max_offset < 0 )) && max_offset=0
      (( offset > max_offset )) && offset="$max_offset"

      tui_render_status_scrolled "$snapshot" "$offset"
      key="$(tui_read_key || true)"
      [[ -n "$key" ]] || continue
      case "$key" in
        up)
          (( offset > 0 )) && offset=$((offset - 1))
          ;;
        down)
          (( offset < max_offset )) && offset=$((offset + 1))
          ;;
        digit:1|char:r|char:R)
          tui_home_accounts_snapshot_cache_clear
          tui_render_status_loading
          tui_home_accounts_snapshot_cached
          snapshot="$TUI_HOME_SNAPSHOT_RENDER"
          offset=0
          ;;
        quit|esc)
          return 0
          ;;
        enter)
          # no-op
          ;;
      esac
    done
  done
}

tui_home_logo() {
  cat <<'EOF'
  ____ ___  ____  _______  __     _____ _        __
 / ___/ _ \|  _ \| ____\ \/ /    / ____\ \      / /
| |  | | | | | | |  _|  \  /____| (___  \ \ /\ / /
| |__| |_| | |_| | |___ /  \_____\___ \  \ V  V /
 \____\___/|____/|_____/_/\_\    |____/   \_/\_/
EOF
}

tui_home_render_plain() {
  local selected="$1"
  local update_hint="${2:-}"
  local i marker index_txt name_txt desc_txt
  local c_logo="" c_link="" c_sel="" c_desc="" c_dim="" c_reset=""
  local -a names=(
    "$(tui_text "$(read_ui_lang)" home_opt_switch)"
    "$(tui_text "$(read_ui_lang)" home_opt_accounts)"
    "$(tui_text "$(read_ui_lang)" home_opt_envs)"
    "$(tui_text "$(read_ui_lang)" home_opt_proxy)"
    "$(tui_text "$(read_ui_lang)" home_opt_status)"
    "$(tui_text "$(read_ui_lang)" home_opt_quit)"
  )
  local -a descs=(
    "Switch active account quickly"
    "Manage accounts"
    "Manage environments"
    "Configure usage API proxy"
    "View usage and status dashboard"
    "Exit"
  )

  tui_clear_screen
  if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
    c_logo="$TUI_COLOR_HILITE"
    c_link="$TUI_COLOR_DIM"
    c_sel="$TUI_COLOR_HILITE"
    c_desc="$TUI_COLOR_DIM"
    c_dim="$TUI_COLOR_DIM"
    c_reset="$TUI_COLOR_RESET"
  fi

  if [[ "$TUI_INTERACTIVE" == "true" ]]; then
    if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
      while IFS= read -r line; do
        printf '%b%s%b\n' "$c_logo" "$line" "$c_reset" >&2
      done < <(tui_home_logo)
      printf '%b%s%b\n' "$c_link" "https://github.com/wxt2rr/codex-switcher" "$c_reset" >&2
    else
      tui_home_logo >&2
      echo "https://github.com/wxt2rr/codex-switcher" >&2
    fi
    echo >&2
    if [[ -n "$update_hint" ]]; then
      if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
        printf '%b%s%b\n' "$c_dim" "$update_hint" "$c_reset" >&2
      else
        echo "$update_hint" >&2
      fi
      echo >&2
    fi
    tui_home_render_menu_block "$selected" "stderr"
  else
    tui_home_logo
    echo "  https://github.com/wxt2rr/codex-switcher"
    echo
    if [[ -n "$update_hint" ]]; then
      echo "  $update_hint"
      echo
    fi
    tui_home_render_menu_block "$selected" "stdout"
  fi
}

tui_home_render_menu_block() {
  local selected="$1"
  local out="${2:-stderr}"
  local i marker index_txt
  local c_sel="" c_desc="" c_dim="" c_reset=""
  local -a names=(
    "$(tui_text "$(read_ui_lang)" home_opt_switch)"
    "$(tui_text "$(read_ui_lang)" home_opt_accounts)"
    "$(tui_text "$(read_ui_lang)" home_opt_envs)"
    "$(tui_text "$(read_ui_lang)" home_opt_proxy)"
    "$(tui_text "$(read_ui_lang)" home_opt_status)"
    "$(tui_text "$(read_ui_lang)" home_opt_quit)"
  )
  local -a descs=(
    "Switch active account quickly"
    "Manage accounts"
    "Manage environments"
    "Configure usage API proxy"
    "View usage and status dashboard"
    "Exit"
  )

  if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
    c_sel="$TUI_COLOR_HILITE"
    c_desc="$TUI_COLOR_DIM"
    c_dim="$TUI_COLOR_DIM"
    c_reset="$TUI_COLOR_RESET"
  fi

  for i in "${!names[@]}"; do
    marker=" "
    index_txt="$((i + 1))."
    if [[ "$i" -eq "$selected" ]]; then
      marker=">"
      if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
        if [[ "$out" == "stderr" ]]; then
          printf '%b%s %s %-14s%b %b%s%b\n' \
            "$c_sel" "$marker" "$index_txt" "${names[$i]}" "$c_reset" \
            "$c_sel" "${descs[$i]}" "$c_reset" >&2
        else
          printf '%b%s %s %-14s%b %b%s%b\n' \
            "$c_sel" "$marker" "$index_txt" "${names[$i]}" "$c_reset" \
            "$c_sel" "${descs[$i]}" "$c_reset"
        fi
      else
        if [[ "$out" == "stderr" ]]; then
          printf '%s %s %-14s %s\n' "$marker" "$index_txt" "${names[$i]}" "${descs[$i]}" >&2
        else
          printf '%s %s %-14s %s\n' "$marker" "$index_txt" "${names[$i]}" "${descs[$i]}"
        fi
      fi
    else
      if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
        if [[ "$out" == "stderr" ]]; then
          printf '  %s %-14s %b%s%b\n' "$index_txt" "${names[$i]}" "$c_desc" "${descs[$i]}" "$c_reset" >&2
        else
          printf '  %s %-14s %b%s%b\n' "$index_txt" "${names[$i]}" "$c_desc" "${descs[$i]}" "$c_reset"
        fi
      else
        if [[ "$out" == "stderr" ]]; then
          printf '  %s %-14s %s\n' "$index_txt" "${names[$i]}" "${descs[$i]}" >&2
        else
          printf '  %s %-14s %s\n' "$index_txt" "${names[$i]}" "${descs[$i]}"
        fi
      fi
    fi
  done
  if [[ "$out" == "stderr" ]]; then
    echo >&2
    if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
      printf '%b%s%b\n' "$c_dim" "$(tui_text "$(read_ui_lang)" nav_hint)" "$c_reset" >&2
    else
      echo "$(tui_text "$(read_ui_lang)" nav_hint)" >&2
    fi
  else
    echo
    if [[ "$TUI_COLOR_ENABLED" == "true" ]]; then
      printf '%b%s%b\n' "$c_dim" "$(tui_text "$(read_ui_lang)" nav_hint)" "$c_reset"
    else
      echo "$(tui_text "$(read_ui_lang)" nav_hint)"
    fi
  fi
}

tui_home_choose_action() {
  local idx=0
  local key d
  local update_hint="${1:-}"
  local menu_lines=8
  local first_render_done="false"
  while true; do
    if [[ "$TUI_INTERACTIVE" == "true" ]]; then
      if [[ "$first_render_done" != "true" ]]; then
        tui_home_render_plain "$idx" "$update_hint"
        first_render_done="true"
      else
        printf '\033[%dA\r' "$menu_lines" >&2
        tui_home_render_menu_block "$idx" "stderr"
      fi
    else
      tui_home_render_plain "$idx" "$update_hint"
    fi
    key="$(tui_read_key || true)"
    [[ -n "$key" ]] || continue
    case "$key" in
      up)
        idx=$(( (idx - 1 + 6) % 6 ))
        ;;
      down)
        idx=$(( (idx + 1) % 6 ))
        ;;
      enter)
        TUI_MENU_RESULT="$idx"
        return 0
        ;;
      quit)
        TUI_MENU_RESULT="-1"
        return 0
        ;;
      digit:*)
        d="${key#digit:}"
        if [[ "$d" =~ ^[0-9]+$ ]]; then
          d=$((d - 1))
          if (( d >= 0 && d < 6 )); then
            TUI_MENU_RESULT="$d"
            return 0
          fi
        fi
        ;;
    esac
  done
}

cmd_tui() {
  local choice update_hint
  tui_setup_terminal
  # Some shells/TTY setups can transiently mark this process as background
  # while app launching/focus switching; ignore TTIN/TTOU to avoid suspend.
  trap '' TTIN TTOU
  trap 'tui_restore_terminal; trap - TTIN TTOU' EXIT INT TERM
  update_hint="$(CODEX_SWITCHER_UPDATE_CHECK_TIMEOUT=1 update_available_message || true)"

  while true; do
    tui_quit_requested && break
    tui_home_choose_action "$update_hint"
    choice="$TUI_MENU_RESULT"
    case "$choice" in
      -1|5)
        break
        ;;
      0)
        tui_action_switch || true
        ;;
      1)
        tui_action_accounts || true
        ;;
      2)
        tui_action_envs || true
        ;;
      3)
        tui_action_proxy || true
        ;;
      4)
        tui_action_status || true
        ;;
    esac
  done

  tui_restore_terminal
  trap - TTIN TTOU
  trap - EXIT INT TERM
}

redact() {
  sed -E \
    -e 's/sk-[A-Za-z0-9_-]{8,}/sk-***REDACTED***/g' \
    -e 's/(access_token|refresh_token|id_token)=([^[:space:]]+)/\1=REDACTED/g'
}

log_event() {
  local level="$1"
  shift
  local message="$*"
  mkdir -p "$STATE_DIR"
  chmod 700 "$STATE_DIR" 2>/dev/null || true
  printf '%s [%s] %s\n' "$(now_utc)" "$level" "$message" | redact >> "$SWITCH_LOG"
}

ensure_dirs() {
  mkdir -p "$STATE_DIR" "$ENVS_DIR" "$ACCOUNTS_DIR"
  mkdir -p "$DEFAULT_HOME"
  chmod 700 "$STATE_DIR" "$ENVS_DIR" "$ACCOUNTS_DIR" "$DEFAULT_HOME" 2>/dev/null || true
}

perm_of() {
  local path="$1"
  if stat -f '%Lp' "$path" >/dev/null 2>&1; then
    stat -f '%Lp' "$path"
  else
    stat -c '%a' "$path"
  fi
}

validate_name_noexit() {
  local name="${1:-}"
  [[ -n "$name" ]] || return 1
  [[ "$name" =~ ^[A-Za-z0-9._-]+$ ]] || return 1
  return 0
}

normalize_name_input() {
  local name="${1:-}"
  # Normalize common full-width punctuation from CJK IME to ASCII.
  name="${name//－/-}"
  name="${name//＿/_}"
  name="${name//．/.}"
  # Remove bracketed-paste wrappers if terminal sent them.
  name="${name//$'\e[200~'/}"
  name="${name//$'\e[201~'/}"
  # Drop control chars (including ESC/CR/LF/TAB) that are invisible on screen.
  name="$(printf '%s' "$name" | tr -d '\000-\037\177')"
  echo "$name"
}

validate_env_name_noexit() {
  local name="${1:-}"
  [[ "$name" == "$DEFAULT_ENV_NAME" ]] && return 0
  validate_name_noexit "$name"
}

validate_env_name() {
  local name="${1:-}"
  validate_env_name_noexit "$name" || err "invalid env '$name' (allowed: A-Z a-z 0-9 . _ -, plus reserved: default)"
}

validate_account_name() {
  local name="${1:-}"
  validate_name_noexit "$name" || err "invalid account '$name' (allowed: A-Z a-z 0-9 . _ -)"
}

env_root_path() {
  local env="$1"
  echo "$ENVS_DIR/$env"
}

env_home_path() {
  local env="$1"
  if [[ "$env" == "$DEFAULT_ENV_NAME" ]]; then
    echo "$DEFAULT_HOME"
  else
    echo "$ENVS_DIR/$env/home"
  fi
}

account_dir_path() {
  local env="$1"
  local account="$2"
  echo "$ACCOUNTS_DIR/$env/$account"
}

account_auth_path() {
  local env="$1"
  local account="$2"
  echo "$(account_dir_path "$env" "$account")/auth.json"
}

current_env_file() {
  local target="$1"
  echo "$STATE_DIR/current_${target}_env"
}

current_account_file() {
  local target="$1"
  echo "$STATE_DIR/current_${target}_account"
}

normalize_usage_proxy_value() {
  local raw="${1:-}"
  local value
  value="$(echo "$raw" | tr -d '\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
  [[ -n "$value" ]] || return 1
  [[ "$value" != *[[:space:]]* ]] || return 1
  case "$value" in
    http://*|https://*|socks5://*)
      echo "$value"
      ;;
    *)
      echo "http://$value"
      ;;
  esac
}

read_usage_proxy() {
  local value
  [[ -f "$USAGE_PROXY_FILE" ]] || return 1
  value="$(head -n 1 "$USAGE_PROXY_FILE" 2>/dev/null || true)"
  normalize_usage_proxy_value "$value"
}

detect_usage_proxy_from_env() {
  local key raw normalized
  for key in CODEX_SWITCHER_USAGE_PROXY HTTPS_PROXY https_proxy HTTP_PROXY http_proxy ALL_PROXY all_proxy; do
    raw="${!key:-}"
    [[ -n "$raw" ]] || continue
    normalized="$(normalize_usage_proxy_value "$raw" || true)"
    [[ -n "$normalized" ]] || continue
    echo "$normalized"
    return 0
  done
  return 1
}

detect_usage_proxy_from_system_macos() {
  [[ "$DISABLE_SYSTEM_PROXY_DETECT" != "true" ]] || return 1
  [[ "$(uname -s 2>/dev/null || true)" == "Darwin" ]] || return 1
  command -v scutil >/dev/null 2>&1 || return 1

  local dump host port enabled normalized
  dump="$(scutil --proxy 2>/dev/null || true)"
  [[ -n "$dump" ]] || return 1

  host="$(echo "$dump" | sed -nE 's/^[[:space:]]*HTTPSProxy[[:space:]]*:[[:space:]]*(.+)$/\1/p' | head -n 1)"
  port="$(echo "$dump" | sed -nE 's/^[[:space:]]*HTTPSPort[[:space:]]*:[[:space:]]*([0-9]+)$/\1/p' | head -n 1)"
  enabled="$(echo "$dump" | sed -nE 's/^[[:space:]]*HTTPSEnable[[:space:]]*:[[:space:]]*([01])$/\1/p' | head -n 1)"
  if [[ "$enabled" == "1" && -n "$host" && -n "$port" ]]; then
    normalized="$(normalize_usage_proxy_value "http://$host:$port" || true)"
    [[ -n "$normalized" ]] && echo "$normalized" && return 0
  fi

  host="$(echo "$dump" | sed -nE 's/^[[:space:]]*HTTPProxy[[:space:]]*:[[:space:]]*(.+)$/\1/p' | head -n 1)"
  port="$(echo "$dump" | sed -nE 's/^[[:space:]]*HTTPPort[[:space:]]*:[[:space:]]*([0-9]+)$/\1/p' | head -n 1)"
  enabled="$(echo "$dump" | sed -nE 's/^[[:space:]]*HTTPEnable[[:space:]]*:[[:space:]]*([01])$/\1/p' | head -n 1)"
  if [[ "$enabled" == "1" && -n "$host" && -n "$port" ]]; then
    normalized="$(normalize_usage_proxy_value "http://$host:$port" || true)"
    [[ -n "$normalized" ]] && echo "$normalized" && return 0
  fi

  host="$(echo "$dump" | sed -nE 's/^[[:space:]]*SOCKSProxy[[:space:]]*:[[:space:]]*(.+)$/\1/p' | head -n 1)"
  port="$(echo "$dump" | sed -nE 's/^[[:space:]]*SOCKSPort[[:space:]]*:[[:space:]]*([0-9]+)$/\1/p' | head -n 1)"
  enabled="$(echo "$dump" | sed -nE 's/^[[:space:]]*SOCKSEnable[[:space:]]*:[[:space:]]*([01])$/\1/p' | head -n 1)"
  if [[ "$enabled" == "1" && -n "$host" && -n "$port" ]]; then
    normalized="$(normalize_usage_proxy_value "socks5://$host:$port" || true)"
    [[ -n "$normalized" ]] && echo "$normalized" && return 0
  fi

  return 1
}

resolve_usage_proxy_with_source() {
  local value

  value="$(read_usage_proxy || true)"
  if [[ -n "$value" ]]; then
    printf 'manual\t%s\n' "$value"
    return 0
  fi

  value="$(detect_usage_proxy_from_env || true)"
  if [[ -n "$value" ]]; then
    printf 'auto-env\t%s\n' "$value"
    return 0
  fi

  value="$(detect_usage_proxy_from_system_macos || true)"
  if [[ -n "$value" ]]; then
    printf 'auto-system\t%s\n' "$value"
    return 0
  fi

  return 1
}

set_usage_proxy() {
  local value="$1"
  local file tmp
  file="$USAGE_PROXY_FILE"
  tmp="${file}.tmp"
  printf '%s\n' "$value" > "$tmp"
  chmod 600 "$tmp" 2>/dev/null || true
  mv "$tmp" "$file"
}

clear_usage_proxy() {
  rm -f -- "$USAGE_PROXY_FILE"
}

display_path_for_output() {
  local path="$1"
  if [[ "$path" == "$HOME" ]]; then
    echo "~"
    return
  fi
  if [[ "$path" == "$HOME/"* ]]; then
    echo "~/${path#$HOME/}"
    return
  fi
  echo "$path"
}

set_current_env() {
  local target="$1"
  local env="$2"
  local file tmp
  file="$(current_env_file "$target")"
  tmp="${file}.tmp"
  printf '%s\n' "$env" > "$tmp"
  chmod 600 "$tmp" 2>/dev/null || true
  mv "$tmp" "$file"
}

set_current_account() {
  local target="$1"
  local account="$2"
  local file tmp
  file="$(current_account_file "$target")"
  tmp="${file}.tmp"
  printf '%s\n' "$account" > "$tmp"
  chmod 600 "$tmp" 2>/dev/null || true
  mv "$tmp" "$file"
}

read_current_env() {
  local target="$1"
  local file value
  file="$(current_env_file "$target")"

  if [[ ! -f "$file" ]]; then
    echo "$DEFAULT_ENV_NAME"
    return 1
  fi

  value="$(head -n 1 "$file" | tr -d '\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
  if ! validate_env_name_noexit "$value"; then
    echo "$DEFAULT_ENV_NAME"
    return 2
  fi

  echo "$value"
  return 0
}

read_current_account() {
  local target="$1"
  local file value
  file="$(current_account_file "$target")"

  if [[ ! -f "$file" ]]; then
    echo "$DEFAULT_ACCOUNT_NAME"
    return 1
  fi

  value="$(head -n 1 "$file" | tr -d '\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
  if ! validate_name_noexit "$value"; then
    echo "$DEFAULT_ACCOUNT_NAME"
    return 2
  fi

  echo "$value"
  return 0
}

ensure_env_home() {
  local env="$1"
  local home
  validate_env_name "$env"
  home="$(env_home_path "$env")"
  mkdir -p "$home"
  if [[ "$env" != "$DEFAULT_ENV_NAME" ]]; then
    mkdir -p "$(env_root_path "$env")"
  fi
  chmod 700 "$home" 2>/dev/null || true
}

env_exists() {
  local env="$1"
  if [[ "$env" == "$DEFAULT_ENV_NAME" ]]; then
    return 0
  fi
  [[ -d "$(env_home_path "$env")" ]]
}

require_env_exists() {
  local env="$1"
  validate_env_name "$env"
  if [[ "$env" == "$DEFAULT_ENV_NAME" ]]; then
    ensure_env_home "$env"
    return 0
  fi
  [[ -d "$(env_home_path "$env")" ]] || err "env '$env' not found. run: $SCRIPT_NAME env create $env"
}

ensure_account_slot() {
  local env="$1"
  local account="$2"
  validate_env_name "$env"
  validate_account_name "$account"
  mkdir -p "$(account_dir_path "$env" "$account")"
  chmod 700 "$(account_dir_path "$env" "$account")" 2>/dev/null || true
}

account_has_auth() {
  local env="$1"
  local account="$2"
  local auth_file home_auth
  auth_file="$(account_auth_path "$env" "$account")"
  if [[ -f "$auth_file" ]]; then
    return 0
  fi
  if [[ "$account" == "$DEFAULT_ACCOUNT_NAME" ]]; then
    home_auth="$(env_home_path "$env")/auth.json"
    [[ -f "$home_auth" ]] && return 0
  fi
  return 1
}

list_env_names() {
  echo "$DEFAULT_ENV_NAME"
  if [[ -d "$ENVS_DIR" ]]; then
    find "$ENVS_DIR" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; | sort | while IFS= read -r env; do
      validate_env_name_noexit "$env" || continue
      [[ "$env" == "$DEFAULT_ENV_NAME" ]] && continue
      [[ -d "$(env_home_path "$env")" ]] || continue
      echo "$env"
    done
  fi
}

list_accounts_for_env() {
  local env="$1"
  local dir any has_default
  dir="$ACCOUNTS_DIR/$env"
  any=0
  has_default=0

  if [[ -d "$dir" ]]; then
    while IFS= read -r account; do
      validate_name_noexit "$account" || continue
      any=1
      [[ "$account" == "$DEFAULT_ACCOUNT_NAME" ]] && has_default=1
      echo "$account"
    done < <(find "$dir" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; | sort)
  fi

  if [[ "$env" == "$DEFAULT_ENV_NAME" && "$has_default" -eq 0 && -f "$(env_home_path "$env")/auth.json" ]]; then
    any=1
    echo "$DEFAULT_ACCOUNT_NAME"
  fi
}

copy_auth_file() {
  local src="$1"
  local dst="$2"
  local tmp
  tmp="${dst}.tmp"
  cp "$src" "$tmp"
  chmod 600 "$tmp" 2>/dev/null || true
  mv "$tmp" "$dst"
}

save_env_auth_to_account() {
  local env="$1"
  local account="$2"
  local home_auth dst
  home_auth="$(env_home_path "$env")/auth.json"
  [[ -f "$home_auth" ]] || return 1
  ensure_account_slot "$env" "$account"
  dst="$(account_auth_path "$env" "$account")"
  copy_auth_file "$home_auth" "$dst"
}

clear_env_auth() {
  local env="$1"
  rm -f -- "$(env_home_path "$env")/auth.json"
}

install_account_auth_to_env() {
  local env="$1"
  local account="$2"
  local src dst
  src="$(account_auth_path "$env" "$account")"
  dst="$(env_home_path "$env")/auth.json"
  if [[ -f "$src" ]]; then
    copy_auth_file "$src" "$dst"
    return 0
  fi
  if [[ "$account" == "$DEFAULT_ACCOUNT_NAME" ]] && [[ -f "$dst" ]]; then
    return 0
  fi
  rm -f -- "$dst"
}

sync_overwrite_excluding_auth() {
  local src="$1"
  local dst="$2"

  [[ -d "$src" ]] || err "sync source not found: $src"
  mkdir -p "$dst"

  if command -v rsync >/dev/null 2>&1; then
    rsync -a --checksum --delete --exclude 'auth.json' "$src/" "$dst/"
  else
    find "$dst" -mindepth 1 -maxdepth 1 ! -name 'auth.json' -exec rm -rf -- {} + 2>/dev/null || true
    (cd "$src" && tar cf - --exclude ./auth.json .) | (cd "$dst" && tar xpf -)
  fi
  chmod 700 "$dst" 2>/dev/null || true
}

acquire_lock() {
  ensure_dirs
  local start now lock_pid
  start="$(date +%s)"

  while true; do
    if mkdir "$LOCK_DIR" 2>/dev/null; then
      printf '%s\n' "$$" > "$LOCK_DIR/pid"
      chmod 700 "$LOCK_DIR" 2>/dev/null || true
      trap 'release_lock' EXIT INT TERM
      return 0
    fi

    lock_pid=""
    if [[ -f "$LOCK_DIR/pid" ]]; then
      lock_pid="$(cat "$LOCK_DIR/pid" 2>/dev/null || true)"
    fi

    if [[ -n "$lock_pid" ]] && ! kill -0 "$lock_pid" >/dev/null 2>&1; then
      rm -rf "$LOCK_DIR" >/dev/null 2>&1 || true
      continue
    fi

    now="$(date +%s)"
    if (( now - start >= LOCK_WAIT_SECONDS )); then
      err "failed to acquire lock within ${LOCK_WAIT_SECONDS}s"
    fi
    sleep 0.1
  done
}

release_lock() {
  if [[ -d "$LOCK_DIR" ]] && [[ -f "$LOCK_DIR/pid" ]]; then
    local lock_pid
    lock_pid="$(cat "$LOCK_DIR/pid" 2>/dev/null || true)"
    if [[ "$lock_pid" == "$$" ]]; then
      rm -rf "$LOCK_DIR" >/dev/null 2>&1 || true
    fi
  fi
}

with_lock() {
  acquire_lock
  "$@"
  release_lock
  trap - EXIT INT TERM
}

with_targets() {
  local target="$1"
  shift
  local fn="$1"
  shift
  case "$target" in
    cli|app)
      "$fn" "$target" "$@"
      ;;
    both)
      "$fn" cli "$@"
      "$fn" app "$@"
      ;;
    *)
      err "invalid target '$target' (use cli|app|both)"
      ;;
  esac
}

target_home_path() {
  local target="$1"
  local env
  env="$(read_current_env "$target" || true)"
  env_home_path "$env"
}

ensure_target_auth_installed() {
  local target="$1"
  local env account
  env="$(read_current_env "$target" || true)"
  account="$(read_current_account "$target" || true)"
  ensure_env_home "$env"
  if account_has_auth "$env" "$account"; then
    install_account_auth_to_env "$env" "$account"
  else
    clear_env_auth "$env"
  fi
}

run_codex_for_target() {
  local target="$1"
  shift
  ensure_target_auth_installed "$target"
  CODEX_HOME="$(target_home_path "$target")" command codex "$@"
}

login_state_for_target() {
  local target="$1"
  local rc home
  ensure_target_auth_installed "$target"
  home="$(target_home_path "$target")"

  rc=0
  CODEX_HOME="$home" command codex login status >/dev/null 2>&1 || rc=$?
  if [[ "$rc" -eq 0 ]]; then
    echo "logged-in"
  else
    echo "not-logged-in"
  fi
}

resolve_app_bin() {
  if [[ -n "${CODEX_SWITCHER_APP_BIN:-}" ]]; then
    [[ -x "$CODEX_SWITCHER_APP_BIN" ]] || err "CODEX_SWITCHER_APP_BIN is not executable: $CODEX_SWITCHER_APP_BIN"
    echo "$CODEX_SWITCHER_APP_BIN"
    return
  fi

  if [[ -x "/Applications/Codex.app/Contents/MacOS/Codex" ]]; then
    echo "/Applications/Codex.app/Contents/MacOS/Codex"
    return
  fi
  if [[ -x "$HOME/Applications/Codex.app/Contents/MacOS/Codex" ]]; then
    echo "$HOME/Applications/Codex.app/Contents/MacOS/Codex"
    return
  fi
  err "Codex.app binary not found. set CODEX_SWITCHER_APP_BIN manually"
}

kill_tree() {
  local pid="$1"
  local child
  if [[ -z "$pid" ]]; then
    return 0
  fi
  for child in $(pgrep -P "$pid" 2>/dev/null || true); do
    kill_tree "$child"
  done
  kill "$pid" >/dev/null 2>&1 || true
}

app_is_running() {
  if [[ ! -f "$APP_PID_FILE" ]]; then
    return 1
  fi
  local pid
  pid="$(cat "$APP_PID_FILE" 2>/dev/null || true)"
  [[ -n "$pid" ]] || return 1
  kill -0 "$pid" >/dev/null 2>&1
}

app_stop_managed() {
  if [[ ! -f "$APP_PID_FILE" ]]; then
    echo "No managed app process to stop"
    return 0
  fi

  local pid
  pid="$(cat "$APP_PID_FILE" 2>/dev/null || true)"
  if [[ -z "$pid" ]]; then
    rm -f "$APP_PID_FILE"
    echo "No managed app process to stop"
    return 0
  fi

  if kill -0 "$pid" >/dev/null 2>&1; then
    log_event INFO "app_stop pid=$pid"
    kill_tree "$pid"
    sleep 0.3
  fi

  rm -f "$APP_PID_FILE"
  echo "Stopped managed app process"
}

app_any_running() {
  pgrep -f "/Codex\\.app/Contents/MacOS/Codex" >/dev/null 2>&1
}

app_stop_unmanaged_if_running() {
  local i
  if [[ "$(uname -s 2>/dev/null || true)" == "Darwin" ]] && command -v osascript >/dev/null 2>&1; then
    osascript -e 'tell application "Codex" to quit' >/dev/null 2>&1 || true
    for ((i=0; i<20; i++)); do
      app_any_running || break
      sleep 0.15
    done
  fi

  if app_any_running; then
    pkill -f "/Codex\\.app/Contents/MacOS/Codex" >/dev/null 2>&1 || true
    sleep 0.2
  fi
}

metrics_script_path() {
  echo "$SCRIPT_DIR/profile-metrics.py"
}

collect_profile_metrics_tsv() {
  local account="$1"
  local auth_file="$2"
  local data_path="$3"
  local usage_proxy="${4:-}"
  local script_path
  script_path="$(metrics_script_path)"
  [[ -f "$script_path" ]] || return 1
  if [[ -n "$usage_proxy" ]]; then
    python3 "$script_path" --account-name "$account" --auth-file "$auth_file" --data-path "$data_path" --usage-proxy "$usage_proxy" 2>/dev/null
  else
    python3 "$script_path" --account-name "$account" --auth-file "$auth_file" --data-path "$data_path" 2>/dev/null
  fi
}

read_api_key_for_login() {
  local api_key="${OPENAI_API_KEY:-}"
  if [[ -n "$api_key" ]]; then
    echo "$api_key"
    return 0
  fi

  if [[ -t 0 ]]; then
    printf "Enter OpenAI API key: " >&2
    IFS= read -r -s api_key || true
    printf "\n" >&2
  else
    IFS= read -r api_key || true
  fi

  api_key="$(echo "${api_key:-}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
  [[ -n "$api_key" ]] || err "empty API key. rerun: $SCRIPT_NAME ac login <account> --mode apikey"
  echo "$api_key"
}

cmd_env_list() {
  local cli_env app_env env marks
  cli_env="$(read_current_env cli || true)"
  app_env="$(read_current_env app || true)"
  list_env_names | sort -u | while IFS= read -r env; do
    marks=""
    [[ "$env" == "$cli_env" ]] && marks="${marks} [cli-current]"
    [[ "$env" == "$app_env" ]] && marks="${marks} [app-current]"
    echo "- $env$marks"
  done
}

cmd_env_create() {
  local env="$1"
  local mode="$2"
  local src_env="${3:-}"
  local home src

  validate_env_name "$env"
  [[ "$env" != "$DEFAULT_ENV_NAME" ]] || err "cannot create reserved env '$DEFAULT_ENV_NAME'"
  if env_exists "$env"; then
    err "env '$env' already exists"
  fi

  home="$(env_home_path "$env")"
  mkdir -p "$home"
  chmod 700 "$home" 2>/dev/null || true

  case "$mode" in
    empty)
      :
      ;;
    from-default)
      sync_overwrite_excluding_auth "$DEFAULT_HOME" "$home"
      ;;
    from-env)
      validate_env_name "$src_env"
      require_env_exists "$src_env"
      src="$(env_home_path "$src_env")"
      sync_overwrite_excluding_auth "$src" "$home"
      ;;
    *)
      err "unknown env create mode: $mode"
      ;;
  esac

  log_event INFO "env_create env=$env mode=$mode src=$src_env"
  echo "Created env: $env"
}

_cmd_env_use_target() {
  local target="$1"
  local env="$2"
  local account

  account="$(read_current_account "$target" || true)"
  set_current_env "$target" "$env"
  if account_has_auth "$env" "$account"; then
    set_current_account "$target" "$account"
    install_account_auth_to_env "$env" "$account"
  else
    set_current_account "$target" "$DEFAULT_ACCOUNT_NAME"
    if account_has_auth "$env" "$DEFAULT_ACCOUNT_NAME"; then
      install_account_auth_to_env "$env" "$DEFAULT_ACCOUNT_NAME"
    else
      clear_env_auth "$env"
    fi
  fi
}

cmd_env_use() {
  local env="$1"
  local target="$2"

  require_env_exists "$env"
  with_targets "$target" _cmd_env_use_target "$env"
  log_event INFO "env_use env=$env target=$target"
  echo "Switched $target env to: $env"
}

cmd_env_remove() {
  local env="$1"
  local force="$2"
  local cli_env app_env

  validate_env_name "$env"
  [[ "$env" != "$DEFAULT_ENV_NAME" ]] || err "cannot remove reserved env '$DEFAULT_ENV_NAME'"
  env_exists "$env" || err "env '$env' not found"

  cli_env="$(read_current_env cli || true)"
  app_env="$(read_current_env app || true)"

  if [[ "$env" == "$cli_env" && "$force" != "true" ]]; then
    err "env '$env' is current CLI env; use --force to remove"
  fi
  if [[ "$env" == "$app_env" && "$force" != "true" ]]; then
    err "env '$env' is current App env; use --force to remove"
  fi

  if ! confirm_delete_twice "env '$env'"; then
    return 0
  fi

  if [[ "$env" == "$app_env" ]]; then
    app_stop_managed >/dev/null
    set_current_env app "$DEFAULT_ENV_NAME"
    set_current_account app "$DEFAULT_ACCOUNT_NAME"
    ensure_target_auth_installed app
  fi
  if [[ "$env" == "$cli_env" ]]; then
    set_current_env cli "$DEFAULT_ENV_NAME"
    set_current_account cli "$DEFAULT_ACCOUNT_NAME"
    ensure_target_auth_installed cli
  fi

  rm -rf -- "$(env_root_path "$env")" "$ACCOUNTS_DIR/$env"
  log_event INFO "env_remove env=$env force=$force"
  echo "Removed env: $env"
}

cmd_env_current() {
  local target="${1:-all}"
  case "$target" in
    cli)
      read_current_env cli || true
      ;;
    app)
      read_current_env app || true
      ;;
    all)
      echo "cli: $(read_current_env cli || true)"
      echo "app: $(read_current_env app || true)"
      ;;
    *)
      err "invalid target '$target' (use cli|app)"
      ;;
  esac
}

cmd_env_path() {
  local env="${1:-$(read_current_env cli || true)}"
  validate_env_name "$env"
  require_env_exists "$env"
  echo "export CODEX_HOME='$(env_home_path "$env")'"
}

cmd_account_add() {
  local account="$1"
  local env="$2"
  validate_account_name "$account"
  require_env_exists "$env"
  ensure_account_slot "$env" "$account"
  log_event INFO "account_add env=$env account=$account"
  echo "Added account slot: $env/$account"
}

cmd_account_remove() {
  local account="$1"
  local env="$2"
  local force="$3"
  local cli_env app_env cli_account app_account

  validate_account_name "$account"
  validate_env_name "$env"

  if [[ ! -d "$(account_dir_path "$env" "$account")" ]] && ! account_has_auth "$env" "$account"; then
    err "account '$account' not found in env '$env'"
  fi

  cli_env="$(read_current_env cli || true)"
  app_env="$(read_current_env app || true)"
  cli_account="$(read_current_account cli || true)"
  app_account="$(read_current_account app || true)"

  if [[ "$env" == "$cli_env" && "$account" == "$cli_account" && "$force" != "true" ]]; then
    err "account '$account' is current CLI account in env '$env'; use --force to remove"
  fi
  if [[ "$env" == "$app_env" && "$account" == "$app_account" && "$force" != "true" ]]; then
    err "account '$account' is current App account in env '$env'; use --force to remove"
  fi

  if ! confirm_delete_twice "account '$env/$account'"; then
    return 0
  fi

  rm -rf -- "$(account_dir_path "$env" "$account")"
  if [[ "$account" == "$DEFAULT_ACCOUNT_NAME" ]]; then
    rm -f -- "$(env_home_path "$env")/auth.json"
  fi

  if [[ "$env" == "$cli_env" && "$account" == "$cli_account" ]]; then
    set_current_account cli "$DEFAULT_ACCOUNT_NAME"
    ensure_target_auth_installed cli
  fi
  if [[ "$env" == "$app_env" && "$account" == "$app_account" ]]; then
    set_current_account app "$DEFAULT_ACCOUNT_NAME"
    ensure_target_auth_installed app
  fi

  log_event INFO "account_remove env=$env account=$account force=$force"
  echo "Removed account slot: $env/$account"
}

cmd_account_list() {
  local env_filter="${1:-}"
  if [[ -n "$env_filter" ]]; then
    require_env_exists "$env_filter"
  fi
  cmd_list "$env_filter"
}

_cmd_account_set_target() {
  local target="$1"
  local env="$2"
  local account="$3"
  set_current_env "$target" "$env"
  set_current_account "$target" "$account"
  install_account_auth_to_env "$env" "$account"
}

cmd_account_login() {
  local account="$1"
  local env="$2"
  local target="$3"
  local sync_mode="$4"
  local mode="$5"
  local home
  local api_key=""

  validate_account_name "$account"
  require_env_exists "$env"
  ensure_env_home "$env"
  home="$(env_home_path "$env")"

  if [[ "$sync_mode" == "true" && "$env" != "$DEFAULT_ENV_NAME" ]]; then
    sync_overwrite_excluding_auth "$DEFAULT_HOME" "$home"
  fi

  case "$mode" in
    auth)
      CODEX_HOME="$home" command codex login
      ;;
    apikey)
      api_key="$(read_api_key_for_login)"
      OPENAI_API_KEY="$api_key" CODEX_HOME="$home" command codex login --with-api-key
      ;;
    *)
      err "invalid mode '$mode' (use auth|apikey)"
      ;;
  esac
  save_env_auth_to_account "$env" "$account" || err "login did not produce auth.json in $home"

  with_targets "$target" _cmd_account_set_target "$env" "$account"

  log_event INFO "account_login env=$env account=$account target=$target sync=$sync_mode mode=$mode"
  if [[ "$mode" == "apikey" ]]; then
    echo "API key saved successfully for account: $env/$account"
  fi
  echo "Logged in account: $env/$account"
}

cmd_account_use() {
  local account="$1"
  local env="$2"
  local target="$3"
  local sync_mode="$4"

  validate_account_name "$account"
  require_env_exists "$env"
  account_has_auth "$env" "$account" || err "account '$account' in env '$env' has no auth.json. run: $SCRIPT_NAME ac login $account --env $env"

  if [[ "$sync_mode" == "true" ]]; then
    warn "same-env account switch only replaces auth.json; --sync is ignored"
  fi

  with_targets "$target" _cmd_account_set_target "$env" "$account"
  log_event INFO "account_use env=$env account=$account target=$target"
  echo "Switched $target account to: $env/$account"
}

cmd_account_logout() {
  local account="$1"
  local env="$2"
  local target="$3"
  local cli_env app_env cli_account app_account

  validate_env_name "$env"
  if [[ -z "$account" ]]; then
    if [[ "$target" == "both" ]]; then
      account="$(read_current_account cli || true)"
    else
      account="$(read_current_account "$target" || true)"
    fi
  fi
  validate_account_name "$account"
  require_env_exists "$env"

  rm -f -- "$(account_auth_path "$env" "$account")"

  cli_env="$(read_current_env cli || true)"
  app_env="$(read_current_env app || true)"
  cli_account="$(read_current_account cli || true)"
  app_account="$(read_current_account app || true)"

  if [[ "$env" == "$cli_env" && "$account" == "$cli_account" ]]; then
    set_current_account cli "$DEFAULT_ACCOUNT_NAME"
    ensure_target_auth_installed cli
  fi
  if [[ "$env" == "$app_env" && "$account" == "$app_account" ]]; then
    set_current_account app "$DEFAULT_ACCOUNT_NAME"
    ensure_target_auth_installed app
  fi

  if [[ "$account" == "$DEFAULT_ACCOUNT_NAME" ]]; then
    rm -f -- "$(env_home_path "$env")/auth.json"
  fi

  log_event INFO "account_logout env=$env account=$account target=$target"
  echo "Logged out account: $env/$account"
}

cmd_account_current() {
  local target="${1:-all}"
  case "$target" in
    cli)
      echo "$(read_current_env cli || true)/$(read_current_account cli || true)"
      ;;
    app)
      echo "$(read_current_env app || true)/$(read_current_account app || true)"
      ;;
    all)
      echo "cli: $(read_current_env cli || true)/$(read_current_account cli || true)"
      echo "app: $(read_current_env app || true)/$(read_current_account app || true)"
      ;;
    *)
      err "invalid target '$target' (use cli|app)"
      ;;
  esac
}

cmd_proxy_show() {
  local info source value
  info="$(resolve_usage_proxy_with_source || true)"
  if [[ -z "$info" ]]; then
    echo "usage_api_proxy: off"
    return 0
  fi
  IFS=$'\t' read -r source value <<< "$info"
  case "$source" in
    manual)
      echo "usage_api_proxy: $value (manual)"
      ;;
    auto-env)
      echo "usage_api_proxy: $value (auto:env)"
      ;;
    auto-system)
      echo "usage_api_proxy: $value (auto:system)"
      ;;
    *)
      echo "usage_api_proxy: $value"
      ;;
  esac
}

cmd_proxy_set() {
  local raw="$1"
  local normalized
  normalized="$(normalize_usage_proxy_value "$raw")" || err "invalid proxy '$raw' (expected host:port or scheme://host:port)"
  set_usage_proxy "$normalized"
  log_event INFO "usage_proxy_set value=$normalized"
  echo "Set usage API proxy: $normalized"
}

cmd_proxy_off() {
  clear_usage_proxy
  log_event INFO "usage_proxy_off"
  echo "Manual usage API proxy disabled"
}

cmd_proxy_test() {
  local proxy env_name account auth_file token body_file http_code body_preview info source
  info="$(resolve_usage_proxy_with_source || true)"
  [[ -n "$info" ]] || err "usage API proxy is off and no auto proxy detected. run: $SCRIPT_NAME proxy <host:port>"
  IFS=$'\t' read -r source proxy <<< "$info"

  env_name="$(read_current_env cli || true)"
  account="$(read_current_account cli || true)"
  auth_file="$(account_auth_path "$env_name" "$account")"
  [[ -f "$auth_file" ]] || auth_file="$(env_home_path "$env_name")/auth.json"
  [[ -f "$auth_file" ]] || err "auth.json not found for current CLI env/account: $env_name/$account"

  token="$(python3 - "$auth_file" <<'PY'
import json, sys
path = sys.argv[1]
try:
    with open(path, "r", encoding="utf-8") as f:
        data = json.load(f)
    token = ((data.get("tokens") or {}).get("access_token") or "").strip()
    print(token)
except Exception:
    print("")
PY
)"
  [[ -n "$token" ]] || err "access_token missing in $auth_file"

  body_file="$(mktemp /tmp/codex-sw-proxy-test.XXXXXX)"
  http_code="$(HTTPS_PROXY="$proxy" HTTP_PROXY="$proxy" curl -sS -o "$body_file" -w '%{http_code}' \
    -H "Authorization: Bearer $token" \
    -H "Accept: application/json" \
    -H "User-Agent: Mozilla/5.0" \
    "$USAGE_API_ENDPOINT" || true)"
  body_preview="$(head -c 160 "$body_file" 2>/dev/null || true)"
  rm -f -- "$body_file"

  if [[ "$http_code" == "200" ]]; then
    echo "usage_api_proxy_test: ok (http=200, source=$source, proxy=$proxy, env/account=$env_name/$account)"
    return 0
  fi

  echo "usage_api_proxy_test: failed (http=${http_code:-000}, source=$source, proxy=$proxy, env/account=$env_name/$account)" >&2
  [[ -n "$body_preview" ]] && echo "response_preview: $body_preview" >&2
  return 1
}

cmd_list() {
  local env_filter="${1:-}"
  local cli_env app_env cli_account app_account
  local env account marks auth_file home home_display metrics
  local email plan usage_5h usage_weekly source last_activity
  local usage_proxy="" usage_info=""

  cli_env="$(read_current_env cli || true)"
  app_env="$(read_current_env app || true)"
  cli_account="$(read_current_account cli || true)"
  app_account="$(read_current_account app || true)"
  usage_info="$(resolve_usage_proxy_with_source || true)"
  if [[ -n "$usage_info" ]]; then
    IFS=$'\t' read -r _ usage_proxy <<< "$usage_info"
  fi

  printf '%-12s %-28s %-30s %-38s %-10s %-20s %-20s %-16s %s\n' "ENV" "HOME" "ACCOUNT" "EMAIL" "PLAN" "5H USAGE" "WEEKLY USAGE" "LAST ACTIVITY" "SOURCE"
  while IFS= read -r env; do
    if [[ -n "$env_filter" && "$env" != "$env_filter" ]]; then
      continue
    fi
    home="$(env_home_path "$env")"
    home_display="$(display_path_for_output "$home")"
    ensure_env_home "$env"
    local found=0
    while IFS= read -r account; do
      found=1
      email=""
      plan=""
      usage_5h=""
      usage_weekly=""
      last_activity=""
      source=""
      marks=""
      [[ "$env" == "$cli_env" && "$account" == "$cli_account" ]] && marks="${marks} [cli-current]"
      [[ "$env" == "$app_env" && "$account" == "$app_account" ]] && marks="${marks} [app-current]"
      auth_file="$(account_auth_path "$env" "$account")"
      [[ -f "$auth_file" ]] || auth_file="$home/auth.json"

      metrics="$(collect_profile_metrics_tsv "$account" "$auth_file" "$home" "$usage_proxy" || true)"
      if [[ -n "$metrics" ]]; then
        IFS=$'\t' read -r email plan usage_5h usage_weekly last_activity source <<< "$metrics"
      fi
      email="${email:-($account)-}"
      plan="${plan:-unknown}"
      usage_5h="${usage_5h:--}"
      usage_weekly="${usage_weekly:--}"
      last_activity="${last_activity:--}"
      source="${source:-local}"
      [[ "$source" == "api" || "$source" == "local" ]] || source="local"

      printf '%-12s %-28s %-30s %-38s %-10s %-20s %-20s %-16s %s\n' "$env" "$home_display" "$account$marks" "$email" "$plan" "$usage_5h" "$usage_weekly" "$last_activity" "$source"
    done < <(list_accounts_for_env "$env")

    if [[ "$found" -eq 0 ]]; then
      email=""
      plan=""
      usage_5h=""
      usage_weekly=""
      last_activity=""
      source=""
      metrics="$(collect_profile_metrics_tsv "-" "$home/auth.json" "$home" "$usage_proxy" || true)"
      if [[ -n "$metrics" ]]; then
        IFS=$'\t' read -r email plan usage_5h usage_weekly last_activity source <<< "$metrics"
      fi
      email="${email:--}"
      plan="${plan:-unknown}"
      usage_5h="${usage_5h:--}"
      usage_weekly="${usage_weekly:--}"
      last_activity="${last_activity:--}"
      source="${source:-local}"
      [[ "$source" == "api" || "$source" == "local" ]] || source="local"
      printf '%-12s %-28s %-30s %-38s %-10s %-20s %-20s %-16s %s\n' "$env" "$home_display" "-" "$email" "$plan" "$usage_5h" "$usage_weekly" "$last_activity" "$source"
    fi
  done < <(list_env_names | sort -u)
}

cmd_import_default() {
  local env="$1"
  local with_auth="$2"
  local force="$3"

  validate_env_name "$env"
  [[ "$env" != "$DEFAULT_ENV_NAME" ]] || err "cannot import into reserved env '$DEFAULT_ENV_NAME'"

  if env_exists "$env"; then
    if [[ "$force" != "true" ]]; then
      err "env '$env' already exists. use --force to overwrite"
    fi
    rm -rf -- "$(env_root_path "$env")" "$ACCOUNTS_DIR/$env"
  fi

  cmd_env_create "$env" "from-default" ""
  if [[ "$with_auth" == "true" && -f "$DEFAULT_HOME/auth.json" ]]; then
    ensure_account_slot "$env" "$DEFAULT_ACCOUNT_NAME"
    copy_auth_file "$DEFAULT_HOME/auth.json" "$(account_auth_path "$env" "$DEFAULT_ACCOUNT_NAME")"
  fi

  log_event INFO "import_default_as_env env=$env with_auth=$with_auth force=$force"
  echo "Imported default data to env: $env"
}

should_launch_codex() {
  local mode="$1"
  case "$mode" in
    true)
      return 0
      ;;
    false)
      return 1
      ;;
    auto)
      [[ -t 0 && -t 1 ]]
      ;;
    *)
      return 1
      ;;
  esac
}

target_includes_cli() {
  local target="$1"
  [[ "$target" == "cli" || "$target" == "both" ]]
}

target_includes_app() {
  local target="$1"
  [[ "$target" == "app" || "$target" == "both" ]]
}

cmd_account_use_and_maybe_launch() {
  local account="$1"
  local env="$2"
  local target="$3"
  local sync_mode="${4:-false}"
  local launch_mode="${5:-auto}"
  shift 5 || true

  with_lock cmd_account_use "$account" "$env" "$target" "$sync_mode"

  if should_launch_codex "$launch_mode"; then
    if target_includes_cli "$target"; then
      echo "Launching codex with env/account: $(read_current_env cli || true)/$(read_current_account cli || true)"
      run_codex_for_target cli "$@"
    fi
    if target_includes_app "$target"; then
      echo "Launching Codex App with env/account: $(read_current_env app || true)/$(read_current_account app || true)"
      cmd_app_open "$account"
    fi
    return 0
  fi

  if [[ "$launch_mode" == "auto" ]]; then
    echo "Auto launch skipped (non-interactive shell). Use --launch to force start."
  fi
  if target_includes_cli "$target"; then
    echo "Run in current shell if needed:"
    echo "  export CODEX_HOME='$(target_home_path cli)'"
  fi
}

cmd_current() {
  local target="${1:-all}"
  case "$target" in
    cli)
      echo "$(read_current_env cli || true)/$(read_current_account cli || true)"
      ;;
    app)
      echo "$(read_current_env app || true)/$(read_current_account app || true)"
      ;;
    all)
      echo "cli: $(read_current_env cli || true)/$(read_current_account cli || true)"
      echo "app: $(read_current_env app || true)/$(read_current_account app || true)"
      ;;
    *)
      err "invalid target '$target' (use cli|app)"
      ;;
  esac
}

cmd_status() {
  local cli_env app_env cli_account app_account
  local cli_ptr_state app_ptr_state cli_acc_state app_acc_state
  local cli_state app_state exit_code

  cli_env="$(read_current_env cli)" || cli_ptr_state=$?
  app_env="$(read_current_env app)" || app_ptr_state=$?
  cli_account="$(read_current_account cli)" || cli_acc_state=$?
  app_account="$(read_current_account app)" || app_acc_state=$?
  cli_ptr_state="${cli_ptr_state:-0}"
  app_ptr_state="${app_ptr_state:-0}"
  cli_acc_state="${cli_acc_state:-0}"
  app_acc_state="${app_acc_state:-0}"

  cli_state="$(login_state_for_target cli)"
  app_state="$(login_state_for_target app)"

  echo "cli_current: $cli_env/$cli_account"
  echo "app_current: $app_env/$app_account"
  echo "cli($cli_env/$cli_account): $cli_state"
  echo "app($app_env/$app_account): $app_state"

  exit_code=0
  if [[ "$cli_ptr_state" -eq 2 || "$app_ptr_state" -eq 2 || "$cli_acc_state" -eq 2 || "$app_acc_state" -eq 2 ]]; then
    echo "hint: pointer file corrupted, run: $SCRIPT_NAME recover" >&2
    exit_code=2
  elif [[ "$cli_state" != "logged-in" || "$app_state" != "logged-in" ]]; then
    exit_code=1
  fi

  return "$exit_code"
}

cmd_exec() {
  [[ "$#" -gt 0 ]] || err "missing codex args. example: $SCRIPT_NAME exec -- login status"
  if [[ "$1" == "--" ]]; then
    shift
  fi
  [[ "$#" -gt 0 ]] || err "missing codex args after --"
  run_codex_for_target cli "$@"
}

cmd_app_open() {
  local account="${1:-}"
  shift || true
  local env app_bin pid login_state use_account

  env="$(read_current_env app || true)"
  use_account="${account:-$(read_current_account app || true)}"
  validate_account_name "$use_account"
  require_env_exists "$env"
  account_has_auth "$env" "$use_account" || err "account '$use_account' not logged in under env '$env'. run: $SCRIPT_NAME ac login $use_account --env $env --target app"

  set_current_env app "$env"
  set_current_account app "$use_account"
  ensure_target_auth_installed app

  login_state="$(login_state_for_target app)"
  if [[ "$login_state" != "logged-in" ]]; then
    err "account '$use_account' in env '$env' is not logged in"
  fi
  app_bin="$(resolve_app_bin)"

  app_stop_managed >/dev/null
  app_stop_unmanaged_if_running >/dev/null

  mkdir -p "$(dirname "$APP_LOG")"
  nohup env CODEX_HOME="$(target_home_path app)" CODEX_SWITCHER_MANAGED=1 CODEX_SWITCHER_ENV="$env" CODEX_SWITCHER_ACCOUNT="$use_account" "$app_bin" "$@" </dev/null >>"$APP_LOG" 2>&1 &
  pid="$!"
  printf '%s\n' "$pid" > "$APP_PID_FILE"
  chmod 600 "$APP_PID_FILE" 2>/dev/null || true

  if [[ "$(uname -s 2>/dev/null || true)" == "Darwin" ]] && command -v osascript >/dev/null 2>&1; then
    (
      sleep 0.35
      osascript -e 'tell application "Codex" to activate' >/dev/null 2>&1 || true
    ) &
  fi

  log_event INFO "app_open env=$env account=$use_account pid=$pid args=$*"
  echo "Opened Codex App with: $env/$use_account"
  echo "App log: $APP_LOG"
}

cmd_app_use() {
  local account="$1"
  shift || true
  cmd_app_open "$account" "$@"
}

cmd_app_logout() {
  local account="${1:-}"
  local env
  env="$(read_current_env app || true)"
  cmd_account_logout "$account" "$env" "app"
}

cmd_app_status() {
  local env account
  env="$(read_current_env app || true)"
  account="$(read_current_account app || true)"
  echo "app_current: $env/$account"
  if app_is_running; then
    echo "app_process: running(pid=$(cat "$APP_PID_FILE"))"
    return 0
  fi
  echo "app_process: not-running"
  return 1
}

cmd_app_stop() {
  app_stop_managed
  log_event INFO "app_stop"
}

cmd_init() {
  local shell_name=""
  local dry_run="false"
  local script_abs target_link rc_file block_start block_end

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --shell)
        shift
        [[ "$#" -gt 0 ]] || err "missing shell after --shell"
        shell_name="$1"
        ;;
      --dry-run)
        dry_run="true"
        ;;
      *)
        err "unknown init option: $1"
        ;;
    esac
    shift
  done

  if [[ -z "$shell_name" ]]; then
    shell_name="$(basename "${SHELL:-zsh}")"
  fi
  case "$shell_name" in
    zsh)
      rc_file="$HOME/.zshrc"
      ;;
    bash)
      rc_file="$HOME/.bashrc"
      ;;
    *)
      err "unsupported shell '$shell_name' (use zsh or bash)"
      ;;
  esac

  script_abs="$SCRIPT_DIR/codex-switcher"
  target_link="$HOME/.local/bin/codex-sw"
  block_start="# >>> codex-sw init >>>"
  block_end="# <<< codex-sw init <<<"

  if [[ "$dry_run" == "true" ]]; then
    echo "[dry-run] mkdir -p $HOME/.local/bin"
    echo "[dry-run] ln -sf $script_abs $target_link"
    echo "[dry-run] ensure PATH block in $rc_file"
    return 0
  fi

  mkdir -p "$HOME/.local/bin"
  ln -sf "$script_abs" "$target_link"

  if [[ ! -f "$rc_file" ]]; then
    touch "$rc_file"
  fi

  if ! grep -qF "$block_start" "$rc_file"; then
    cat >> "$rc_file" <<RC
$block_start
export PATH="\$HOME/.local/bin:\$PATH"
$block_end
RC
  fi

  log_event INFO "init shell=$shell_name rc_file=$rc_file"
  echo "Initialized codex-sw for $shell_name"
  echo "Run: source $rc_file"
}

cmd_upgrade() {
  local dry_run="${1:-false}"
  local registry npm_package cmdline

  command -v npm >/dev/null 2>&1 || err "npm command not found; cannot upgrade. install npm first"
  registry="${CODEX_SWITCHER_UPGRADE_REGISTRY:-https://registry.npmjs.org/}"
  npm_package="${CODEX_SWITCHER_NPM_PACKAGE:-@wangxt0223/codex-switcher}"
  cmdline=(npm i -g "${npm_package}@latest" --registry "$registry")

  if [[ "$dry_run" == "true" ]]; then
    echo "[dry-run] ${cmdline[*]}"
    return 0
  fi

  log_event INFO "upgrade package=$npm_package registry=$registry"
  "${cmdline[@]}"
  echo "Upgraded codex-sw to latest."
}

cmd_recover() {
  local dry_run="${1:-false}"
  local target env account

  for target in cli app; do
    env="$(read_current_env "$target" || true)"
    account="$(read_current_account "$target" || true)"
    validate_env_name_noexit "$env" || env="$DEFAULT_ENV_NAME"
    if [[ "$env" != "$DEFAULT_ENV_NAME" ]] && [[ ! -d "$(env_home_path "$env")" ]]; then
      env="$DEFAULT_ENV_NAME"
    fi
    validate_name_noexit "$account" || account="$DEFAULT_ACCOUNT_NAME"
    if ! account_has_auth "$env" "$account"; then
      account="$DEFAULT_ACCOUNT_NAME"
    fi

    if [[ "$dry_run" != "true" ]]; then
      set_current_env "$target" "$env"
      set_current_account "$target" "$account"
      ensure_target_auth_installed "$target"
    fi

    echo "recover($target): $env/$account"
  done

  if [[ "$dry_run" == "true" ]]; then
    return 0
  fi

  log_event INFO "recover cli=$(read_current_env cli || true)/$(read_current_account cli || true) app=$(read_current_env app || true)/$(read_current_account app || true)"
}

scan_logs_for_secrets() {
  local found=0
  if [[ -f "$SWITCH_LOG" ]] && grep -E 'sk-[A-Za-z0-9_-]{8,}|(access_token|refresh_token|id_token)=' "$SWITCH_LOG" >/dev/null 2>&1; then
    echo "redaction_check: failed ($SWITCH_LOG contains potential secrets)" >&2
    found=1
  fi
  if [[ -f "$APP_LOG" ]] && grep -E 'sk-[A-Za-z0-9_-]{8,}|(access_token|refresh_token|id_token)=' "$APP_LOG" >/dev/null 2>&1; then
    echo "redaction_check: failed ($APP_LOG contains potential secrets)" >&2
    found=1
  fi
  return "$found"
}

cmd_check() {
  command -v codex >/dev/null 2>&1 || err "codex command not found in PATH"
  resolve_app_bin >/dev/null
  ensure_dirs

  local pstate=0
  read_current_env cli >/dev/null || pstate=$?
  if [[ "$pstate" -eq 2 ]]; then
    err "current_cli_env pointer corrupted; run: $SCRIPT_NAME recover"
  fi
  pstate=0
  read_current_env app >/dev/null || pstate=$?
  if [[ "$pstate" -eq 2 ]]; then
    err "current_app_env pointer corrupted; run: $SCRIPT_NAME recover"
  fi
  pstate=0
  read_current_account cli >/dev/null || pstate=$?
  if [[ "$pstate" -eq 2 ]]; then
    err "current_cli_account pointer corrupted; run: $SCRIPT_NAME recover"
  fi
  pstate=0
  read_current_account app >/dev/null || pstate=$?
  if [[ "$pstate" -eq 2 ]]; then
    err "current_app_account pointer corrupted; run: $SCRIPT_NAME recover"
  fi

  if ! scan_logs_for_secrets; then
    err "log redaction check failed"
  fi

  echo "version: $(switcher_version)"
  echo "check: ok"
}

cmd_version() {
  echo "$(switcher_version)"
}

cmd_doctor() {
  local fix="${1:-false}"
  local issues=0
  local state_perm envs_perm accounts_perm

  ensure_dirs
  state_perm="$(perm_of "$STATE_DIR")"
  envs_perm="$(perm_of "$ENVS_DIR")"
  accounts_perm="$(perm_of "$ACCOUNTS_DIR")"

  echo "state_dir: $STATE_DIR (perm=$state_perm)"
  echo "envs_dir: $ENVS_DIR (perm=$envs_perm)"
  echo "accounts_dir: $ACCOUNTS_DIR (perm=$accounts_perm)"
  echo "default_home: $DEFAULT_HOME (perm=$(perm_of "$DEFAULT_HOME"))"
  echo "cli_current: $(read_current_env cli || true)/$(read_current_account cli || true)"
  echo "app_current: $(read_current_env app || true)/$(read_current_account app || true)"

  if ! command -v codex >/dev/null 2>&1; then
    echo "- codex in PATH: missing"
    issues=1
  else
    echo "- codex in PATH: ok"
  fi

  if resolve_app_bin >/dev/null 2>&1; then
    echo "- codex app binary: ok ($(resolve_app_bin))"
  else
    echo "- codex app binary: missing"
    issues=1
  fi

  if [[ "$state_perm" != "700" || "$envs_perm" != "700" || "$accounts_perm" != "700" ]]; then
    issues=1
    echo "- directory permissions are not strict 700"
  fi

  if ! scan_logs_for_secrets; then
    issues=1
  else
    echo "- redaction check: ok"
  fi

  if [[ "$fix" == "true" ]]; then
    chmod 700 "$STATE_DIR" "$ENVS_DIR" "$ACCOUNTS_DIR" "$DEFAULT_HOME" 2>/dev/null || true
    with_lock cmd_recover false
    issues=0
    if ! scan_logs_for_secrets; then
      issues=1
    fi
    echo "doctor --fix: completed"
  fi

  if [[ "$issues" -eq 0 ]]; then
    echo "doctor: ok"
    return 0
  fi

  echo "doctor: issues found"
  if [[ "$fix" != "true" ]]; then
    echo "Run: $SCRIPT_NAME doctor --fix"
  fi
  return 1
}

main() {
  ensure_dirs

  local cmd="${1:-}"
  if [[ -z "$cmd" ]]; then
    cmd="tui"
  else
    shift || true
  fi
  if [[ "$cmd" != "tui" ]]; then
    notify_update_if_available
  fi

  case "$cmd" in
    env)
      local sub="${1:-}"
      [[ -n "$sub" ]] || err "usage: $SCRIPT_NAME env <ls|new|use|rm> ..."
      shift || true
      case "$sub" in
        ls)
          [[ "$#" -eq 0 ]] || err "usage: $SCRIPT_NAME env ls"
          cmd_env_list
          ;;
        new)
          [[ "$#" -ge 1 ]] || err "usage: $SCRIPT_NAME env new <env> [--empty|--from <src-env|default>]"
          local env="$1"
          shift
          local mode="from-default"
          local src_env=""
          while [[ "$#" -gt 0 ]]; do
            case "$1" in
              --empty)
                mode="empty"
                ;;
              --from)
                shift
                [[ "$#" -gt 0 ]] || err "missing source env after --from"
                if [[ "$1" == "$DEFAULT_ENV_NAME" ]]; then
                  mode="from-default"
                  src_env=""
                else
                  mode="from-env"
                  src_env="$1"
                fi
                ;;
              *)
                err "unknown option: $1"
                ;;
            esac
            shift
          done
          with_lock cmd_env_create "$env" "$mode" "$src_env"
          ;;
        use)
          [[ "$#" -ge 1 ]] || err "usage: $SCRIPT_NAME env use <env> [-t cli|app|both]"
          local env="$1"
          shift
          local target="cli"
          while [[ "$#" -gt 0 ]]; do
            case "$1" in
              -t|--target)
                shift
                [[ "$#" -gt 0 ]] || err "missing target after -t/--target"
                target="$1"
                ;;
              *)
                err "unknown option: $1"
                ;;
            esac
            shift
          done
          with_lock cmd_env_use "$env" "$target"
          ;;
        rm|remove|delete)
          [[ "$#" -ge 1 && "$#" -le 2 ]] || err "usage: $SCRIPT_NAME env rm <env> [--force]"
          local env="$1"
          shift
          local force="false"
          if [[ "${1:-}" == "--force" ]]; then
            force="true"
          elif [[ -n "${1:-}" ]]; then
            err "unknown option: ${1:-}"
          fi
          with_lock cmd_env_remove "$env" "$force"
          ;;
        *)
          err "unknown env subcommand: $sub"
          ;;
      esac
      ;;
    account|ac)
      local sub="${1:-}"
      [[ -n "$sub" ]] || err "usage: $SCRIPT_NAME ac <ls|login|use|logout|rm> ..."
      shift || true
      case "$sub" in
        ls)
          local env=""
          while [[ "$#" -gt 0 ]]; do
            case "$1" in
              --env)
                shift
                [[ "$#" -gt 0 ]] || err "missing env after --env"
                env="$1"
                ;;
              *)
                err "unknown option: $1"
                ;;
            esac
            shift
          done
          cmd_account_list "$env"
          ;;
        login)
          [[ "$#" -ge 1 ]] || err "usage: $SCRIPT_NAME ac login <account> [--env <env>] [-t cli|app|both] [--sync|--no-sync] [--mode auth|apikey]"
          local account="$1"
          shift
          local env="$(read_current_env cli || true)"
          local target="cli"
          local sync_mode="false"
          local mode="auth"
          while [[ "$#" -gt 0 ]]; do
            case "$1" in
              --env)
                shift
                [[ "$#" -gt 0 ]] || err "missing env after --env"
                env="$1"
                ;;
              -t|--target)
                shift
                [[ "$#" -gt 0 ]] || err "missing target after -t/--target"
                target="$1"
                ;;
              --sync)
                sync_mode="true"
                ;;
              --no-sync)
                sync_mode="false"
                ;;
              --mode)
                shift
                [[ "$#" -gt 0 ]] || err "missing mode after --mode"
                mode="$1"
                ;;
              *)
                err "unknown option: $1"
                ;;
            esac
            shift
          done
          case "$mode" in
            auth|apikey)
              ;;
            *)
              err "invalid mode '$mode' (use auth|apikey)"
              ;;
          esac
          with_lock cmd_account_login "$account" "$env" "$target" "$sync_mode" "$mode"
          ;;
        use)
          [[ "$#" -ge 1 ]] || err "usage: $SCRIPT_NAME ac use <account> [--env <env>] [-t cli|app|both] [--sync|--no-sync] [--launch|--no-launch] [-- <codex args...>]"
          local account="$1"
          shift
          local env="$(read_current_env cli || true)"
          local target="cli"
          local sync_mode="false"
          local launch="auto"
          local codex_args=()
          while [[ "$#" -gt 0 ]]; do
            case "$1" in
              --env)
                shift
                [[ "$#" -gt 0 ]] || err "missing env after --env"
                env="$1"
                ;;
              -t|--target)
                shift
                [[ "$#" -gt 0 ]] || err "missing target after -t/--target"
                target="$1"
                ;;
              --sync)
                sync_mode="true"
                ;;
              --no-sync)
                sync_mode="false"
                ;;
              --launch)
                launch="true"
                ;;
              --no-launch)
                launch="false"
                ;;
              --)
                shift
                codex_args=("$@")
                break
                ;;
              *)
                err "unknown option: $1"
                ;;
            esac
            shift
          done

          if [[ "$target" == "app" && "${#codex_args[@]}" -gt 0 ]]; then
            err "cannot pass codex args with -t app"
          fi
          if [[ "${#codex_args[@]}" -gt 0 ]]; then
            [[ "$launch" != "false" ]] || err "cannot pass codex args with --no-launch"
            launch="true"
          fi
          if [[ "${#codex_args[@]}" -gt 0 ]]; then
            cmd_account_use_and_maybe_launch "$account" "$env" "$target" "$sync_mode" "$launch" "${codex_args[@]}"
          else
            cmd_account_use_and_maybe_launch "$account" "$env" "$target" "$sync_mode" "$launch"
          fi
          ;;
        logout)
          local account=""
          local env="$(read_current_env cli || true)"
          local target="cli"
          if [[ "$#" -gt 0 && "${1:-}" != --* ]]; then
            account="$1"
            shift
          fi
          while [[ "$#" -gt 0 ]]; do
            case "$1" in
              --env)
                shift
                [[ "$#" -gt 0 ]] || err "missing env after --env"
                env="$1"
                ;;
              -t|--target)
                shift
                [[ "$#" -gt 0 ]] || err "missing target after -t/--target"
                target="$1"
                ;;
              *)
                err "unknown option: $1"
                ;;
            esac
            shift
          done
          with_lock cmd_account_logout "$account" "$env" "$target"
          ;;
        rm|remove|delete)
          [[ "$#" -ge 1 ]] || err "usage: $SCRIPT_NAME ac rm <account> [--env <env>] [--force]"
          local account="$1"
          shift
          local env="$(read_current_env cli || true)"
          local force="false"
          while [[ "$#" -gt 0 ]]; do
            case "$1" in
              --env)
                shift
                [[ "$#" -gt 0 ]] || err "missing env after --env"
                env="$1"
                ;;
              --force)
                force="true"
                ;;
              *)
                err "unknown option: $1"
                ;;
            esac
            shift
          done
          with_lock cmd_account_remove "$account" "$env" "$force"
          ;;
        *)
          err "unknown account subcommand: $sub"
          ;;
      esac
      ;;
    whoami)
      local target="all"
      if [[ "$#" -gt 0 ]]; then
        case "$1" in
          -t|--target)
            shift
            [[ "$#" -gt 0 ]] || err "missing target after -t/--target"
            target="$1"
            shift
            ;;
          *)
            err "unknown option: $1"
            ;;
        esac
      fi
      [[ "$#" -eq 0 ]] || err "usage: $SCRIPT_NAME whoami [-t cli|app|both]"
      case "$target" in
        cli|app)
          cmd_current "$target"
          ;;
        both|all)
          cmd_current all
          ;;
        *)
          err "invalid target '$target' (use cli|app|both)"
          ;;
      esac
      ;;
    status)
      [[ "$#" -eq 0 ]] || err "usage: $SCRIPT_NAME status"
      cmd_status
      ;;
    lang)
      [[ "$#" -le 1 ]] || err "usage: $SCRIPT_NAME lang [zh|en|ja]"
      cmd_lang "${1:-}"
      ;;
    tui)
      [[ "$#" -eq 0 ]] || err "usage: $SCRIPT_NAME tui"
      cmd_tui
      ;;
    check)
      [[ "$#" -eq 0 ]] || err "usage: $SCRIPT_NAME check"
      cmd_check
      ;;
    upgrade)
      [[ "$#" -le 1 ]] || err "usage: $SCRIPT_NAME upgrade [--dry-run]"
      local dry="false"
      if [[ "${1:-}" == "--dry-run" ]]; then
        dry="true"
      elif [[ -n "${1:-}" ]]; then
        err "unknown option: ${1:-}"
      fi
      cmd_upgrade "$dry"
      ;;
    ops)
      local sub="${1:-}"
      [[ -n "$sub" ]] || err "usage: $SCRIPT_NAME ops <list|proxy|exec|import-default|init|recover|doctor> ..."
      shift || true
      case "$sub" in
        list)
          [[ "$#" -eq 0 ]] || err "usage: $SCRIPT_NAME ops list"
          cmd_list
          ;;
        proxy)
          [[ "$#" -le 1 ]] || err "usage: $SCRIPT_NAME ops proxy [<host:port>|off|test]"
          case "${1:-}" in
            "")
              cmd_proxy_show
              ;;
            off)
              with_lock cmd_proxy_off
              ;;
            test)
              cmd_proxy_test
              ;;
            *)
              with_lock cmd_proxy_set "$1"
              ;;
          esac
          ;;
        exec)
          cmd_exec "$@"
          ;;
        import-default)
          [[ "$#" -ge 1 ]] || err "usage: $SCRIPT_NAME ops import-default <env> [--with-auth] [--force]"
          local env="$1"
          local with_auth="false"
          local force="false"
          shift
          while [[ "$#" -gt 0 ]]; do
            case "$1" in
              --with-auth)
                with_auth="true"
                ;;
              --force)
                force="true"
                ;;
              *)
                err "unknown option: $1"
                ;;
            esac
            shift
          done
          with_lock cmd_import_default "$env" "$with_auth" "$force"
          ;;
        init)
          cmd_init "$@"
          ;;
        recover)
          [[ "$#" -le 1 ]] || err "usage: $SCRIPT_NAME ops recover [--dry-run]"
          local dry="false"
          if [[ "${1:-}" == "--dry-run" ]]; then
            dry="true"
          elif [[ -n "${1:-}" ]]; then
            err "unknown option: ${1:-}"
          fi
          with_lock cmd_recover "$dry"
          ;;
        doctor)
          [[ "$#" -le 1 ]] || err "usage: $SCRIPT_NAME ops doctor [--fix]"
          local fix="false"
          if [[ "${1:-}" == "--fix" ]]; then
            fix="true"
          elif [[ -n "${1:-}" ]]; then
            err "unknown option: ${1:-}"
          fi
          cmd_doctor "$fix"
          ;;
        help|-h|--help)
          usage_all
          ;;
        *)
          err "unknown ops subcommand: $sub"
          ;;
      esac
      ;;
    version)
      [[ "$#" -eq 0 ]] || err "usage: $SCRIPT_NAME version"
      cmd_version
      ;;
    --help-all|help-all)
      usage_all
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      err "unknown command: $cmd"
      ;;
  esac
}

main "$@"
