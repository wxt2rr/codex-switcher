#!/usr/bin/env bash
set -euo pipefail

resolve_script_dir() {
  local src="${BASH_SOURCE[0]}"
  local dir
  while [[ -h "$src" ]]; do
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" == /* ]] || src="$dir/$src"
  done
  cd -P "$(dirname "$src")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"

STATE_DIR="${CODEX_SWITCHER_STATE_DIR:-$HOME/.codex-switcher}"
ENVS_DIR="${CODEX_SWITCHER_ENVS_DIR:-$HOME/.codex-envs}"
ACCOUNTS_DIR="${CODEX_SWITCHER_ACCOUNTS_DIR:-$STATE_DIR/env-accounts}"
DEFAULT_HOME="${CODEX_SWITCHER_DEFAULT_HOME:-$HOME/.codex}"
DEFAULT_ENV_NAME="default"
DEFAULT_ACCOUNT_NAME="default"
DEFAULT_UI_LANG="en"

APP_LOG="${CODEX_SWITCHER_APP_LOG:-$STATE_DIR/app.log}"
SWITCH_LOG="${CODEX_SWITCHER_SWITCH_LOG:-$STATE_DIR/switcher.log}"
APP_PID_FILE="$STATE_DIR/app.pid"
LOCK_DIR="$STATE_DIR/.lock"
LOCK_WAIT_SECONDS="${CODEX_SWITCHER_LOCK_WAIT_SECONDS:-10}"

SCRIPT_NAME="${CODEX_SWITCHER_INVOKED_AS:-$(basename "$0")}"
USAGE_API_ENDPOINT="https://chatgpt.com/backend-api/wham/usage"
USAGE_PROXY_FILE="$STATE_DIR/usage_proxy"
DISABLE_SYSTEM_PROXY_DETECT="${CODEX_SWITCHER_DISABLE_SYSTEM_PROXY_DETECT:-false}"

usage() {
  cat <<'USAGE'
Usage:
  codex-sw env ls
  codex-sw env new <env> [--empty|--from <src-env|default>]
  codex-sw env use <env> [-t cli|app|both]
  codex-sw env rm <env> [--force]

  codex-sw ac ls [--env <env>]
  codex-sw ac login <account> [--env <env>] [-t cli|app|both] [--sync|--no-sync] [--mode auth|apikey]
  codex-sw ac use <account> [--env <env>] [-t cli|app|both] [--sync|--no-sync] [--launch|--no-launch] [-- <codex args...>]
  codex-sw ac logout [account] [--env <env>] [-t cli|app|both]
  codex-sw ac rm <account> [--env <env>] [--force]

  codex-sw whoami [-t cli|app|both]
  codex-sw status
  codex-sw lang [en]
  codex-sw tui
  codex-sw check
  codex-sw upgrade [--dry-run]
  codex-sw version
  codex-sw --help
  codex-sw --help-all

Notes:
  - `ac` and `account` are equivalent.
  - Use `--help-all` to show operations under `ops`.
USAGE
}

usage_all() {
  cat <<'USAGE'
Usage:
  codex-sw env ls
  codex-sw env new <env> [--empty|--from <src-env|default>]
  codex-sw env use <env> [-t cli|app|both]
  codex-sw env rm <env> [--force]

  codex-sw ac ls [--env <env>]
  codex-sw ac login <account> [--env <env>] [-t cli|app|both] [--sync|--no-sync] [--mode auth|apikey]
  codex-sw ac use <account> [--env <env>] [-t cli|app|both] [--sync|--no-sync] [--launch|--no-launch] [-- <codex args...>]
  codex-sw ac logout [account] [--env <env>] [-t cli|app|both]
  codex-sw ac rm <account> [--env <env>] [--force]

  codex-sw whoami [-t cli|app|both]
  codex-sw status
  codex-sw lang [en]
  codex-sw tui
  codex-sw check
  codex-sw upgrade [--dry-run]
  codex-sw version

  codex-sw ops list
  codex-sw ops proxy [<host:port>|off|test]
  codex-sw ops exec -- <codex args...>
  codex-sw ops import-default <env> [--with-auth] [--force]
  codex-sw ops init [--shell zsh|bash] [--dry-run]
  codex-sw ops recover [--dry-run]
  codex-sw ops doctor [--fix]
USAGE
}

err() {
  echo "Error: $*" >&2
  exit 1
}

warn() {
  echo "Warning: $*" >&2
}

confirm_yes_no() {
  local prompt="$1"
  local answer

  printf "%s [y/N]: " "$prompt" >&2
  if ! IFS= read -r answer; then
    return 1
  fi

  case "$answer" in
    y|Y|yes|YES)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

confirm_delete_twice() {
  local target="$1"
  if ! confirm_yes_no "Remove ${target}?"; then
    echo "Cancelled"
    return 1
  fi
  if ! confirm_yes_no "Final confirmation: remove ${target}"; then
    echo "Cancelled"
    return 1
  fi
  return 0
}

ui_lang_file() {
  echo "$STATE_DIR/ui_lang"
}

normalize_ui_lang() {
  local raw="${1:-}"
  local normalized
  normalized="$(echo "$raw" | tr '[:upper:]' '[:lower:]' | tr -d '\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
  case "$normalized" in
    en)
      echo "$normalized"
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

read_ui_lang() {
  echo "en"
}

set_ui_lang() {
  local lang="$1"
  local file tmp
  file="$(ui_lang_file)"
  tmp="${file}.tmp"
  printf '%s\n' "$lang" > "$tmp"
  chmod 600 "$tmp" 2>/dev/null || true
  mv "$tmp" "$file"
}

cmd_lang() {
  local value="${1:-}"

  if [[ -z "$value" ]]; then
    echo "language: en"
    return 0
  fi

  value="$(echo "$value" | tr '[:upper:]' '[:lower:]' | tr -d '\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
  [[ "$value" == "en" ]] || err "invalid language '$value' (English-only build, use en)"
  echo "language set to: en"
}

now_utc() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

switcher_version() {
  local package_json version
  package_json="$(cd "$SCRIPT_DIR/../../.." && pwd)/package.json"

  if [[ -f "$package_json" ]]; then
    version="$(sed -nE 's/^[[:space:]]*"version"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/p' "$package_json" | head -n 1)"
  fi

  echo "${version:-unknown}"
}

switcher_package_name() {
  local package_json name
  package_json="$(cd "$SCRIPT_DIR/../../.." && pwd)/package.json"

  if [[ -f "$package_json" ]]; then
    name="$(sed -nE 's/^[[:space:]]*"name"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/p' "$package_json" | head -n 1)"
  fi

  echo "${name:-}"
}

semver_is_newer() {
  local latest="${1:-}"
  local current="${2:-}"
  local latest_core current_core
  local lmaj lmin lpat cmaj cmin cpat

  latest_core="$(echo "$latest" | sed -E 's/^v//; s/^([0-9]+\.[0-9]+\.[0-9]+).*$/\1/')"
  current_core="$(echo "$current" | sed -E 's/^v//; s/^([0-9]+\.[0-9]+\.[0-9]+).*$/\1/')"

  [[ "$latest_core" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] || return 1
  [[ "$current_core" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] || return 1

  IFS='.' read -r lmaj lmin lpat <<< "$latest_core"
  IFS='.' read -r cmaj cmin cpat <<< "$current_core"

  if (( lmaj > cmaj )); then
    return 0
  fi
  if (( lmaj < cmaj )); then
    return 1
  fi
  if (( lmin > cmin )); then
    return 0
  fi
  if (( lmin < cmin )); then
    return 1
  fi
  if (( lpat > cpat )); then
    return 0
  fi
  return 1
}

notify_update_if_available() {
  local message
  message="$(update_available_message || true)"
  [[ -n "$message" ]] && echo "$message" >&2
  return 0
}

update_available_message() {
  local current_version package_name latest_version timeout_secs tmp pid waited_ticks
  [[ "${CODEX_SWITCHER_SKIP_UPDATE_CHECK:-false}" == "true" ]] && return 0
  current_version="$(switcher_version)"
  package_name="$(switcher_package_name)"

  [[ -n "$package_name" ]] || return 0
  [[ "$current_version" != "unknown" ]] || return 0
  command -v npm >/dev/null 2>&1 || return 0

  timeout_secs="${CODEX_SWITCHER_UPDATE_CHECK_TIMEOUT:-3}"
  [[ "$timeout_secs" =~ ^[0-9]+$ ]] || timeout_secs="3"
  (( timeout_secs > 0 )) || return 0

  tmp="$(mktemp /tmp/codex-sw-update-check.XXXXXX)"
  (
    npm view "$package_name" version --registry "https://registry.npmjs.org/" >"$tmp" 2>/dev/null
  ) &
  pid=$!
  waited_ticks=0
  while kill -0 "$pid" 2>/dev/null; do
    if (( waited_ticks >= timeout_secs * 10 )); then
      kill "$pid" 2>/dev/null || true
      wait "$pid" 2>/dev/null || true
      rm -f "$tmp"
      return 0
    fi
    sleep 0.1
    waited_ticks=$((waited_ticks + 1))
  done
  wait "$pid" 2>/dev/null || true

  latest_version="$(head -n 1 "$tmp" 2>/dev/null | tr -d '\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
  rm -f "$tmp"
  [[ -n "$latest_version" ]] || return 0

  if semver_is_newer "$latest_version" "$current_version"; then
    echo "Update available: $current_version -> $latest_version. run codex-sw upgrade"
  fi
}

tui_catalog_lines() {
  usage | sed -nE 's/^  codex-sw (.+)$/\1/p'
}

